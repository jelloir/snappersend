# snappersend config — /etc/snappersend/config
# =============================================================================
# REQUIRES: Snapper installed and taking timeline snapshots on this (source) host.
# snappersend replicates Snapper's snapshots; it does not create them.
#
# Flat KEY="value" file, the SAME format as Snapper's own config files
# (/etc/snapper/configs/<name>), parsed by python-dotenv. The retention block uses
# Snapper's exact TIMELINE_LIMIT_* names so if you run Snapper you already know it.
#
# Inline "# comments", spaces around "=", quoted or unquoted values, and blank
# lines are all fine. Keys snappersend doesn't recognise (e.g. Snapper's own
# SUBVOLUME/FSTYPE/NUMBER_LIMIT/...) are ignored without error, so you can keep
# Snapper-style keys around for reference.

# ---- Destination transport ---------------------------------------------------
SERVER_HOST="dest-host"                       # REQUIRED — the receive end (edit this)
SSH_PORT="22"
SERVER_USER="snappersend"                     # dedicated least-privilege transport user
SSH_KEY="/etc/snappersend/ssh/id_ed25519"
RECV_BASE="/srv/snapshots-recv"               # -> <RECV_BASE>/<this-hostname>/<subvol>/...
USE_MBUFFER="yes"                             # smooth throughput, a live rate readout on a
                                              # tty, and per-transfer stats in the log
                                              # (stream size = changed data, time, avg rate)

# ---- Subvolumes to replicate -------------------------------------------------
# Space-separated  name:mountpoint  pairs. The mountpoint is where that subvol's
# Snapper .snapshots directory lives (e.g. "/" and "/home").
SUBVOLUMES="root:/ home:/home"

# ---- Parent-preservation tree (snappersend's incremental base) ---------------
# snappersend keeps read-only clones of the snapshots it has confirmed-sent here,
# on the SAME Btrfs filesystem as the source (reflinked, near-zero space). These
# clones are the -p parents for future incrementals and are immune to Snapper's
# own retention, so an incremental survives an arbitrary offline gap.
PARENT_TREE_BASE="/.snappersend"
PARENT_KEEP="2"                               # live parent + 1 redundancy slot

# ---- Boot tier (optional) ----------------------------------------------------
# /boot + /boot/efi are not Btrfs, so btrfs send can't carry them; rsync is the
# transport and the DESTINATION does the versioning. The layout matches the
# snapshot tiers (parent dir, dated backups below, a .latest symlink):
#
#   <RECV_BASE>/<hostname>/boot/          (and boot-efi/)
#       .mirror                           live rsync target (subvolume; hidden
#                                         like .snapshots — machinery, not a backup)
#       <date-stamp>                      read-only versions of the mirror, named
#                                         with the same YYYYMMDD-HHMMSS±ZZZZ label
#                                         as the subvol dir names (no num/uuid)
#       boot.latest -> <date-stamp>       newest version
#
# A new version is created only when a clean sync actually CHANGED the mirror —
# an unchanged re-run creates nothing, the same idempotence as the snapshot
# tiers. Retention over the versions uses the TIMELINE_LIMIT_* block below, with
# optional per-path overrides (see the overrides section at the bottom). FAT32's
# 2-second mtime granularity is handled automatically (--modify-window=1 for
# vfat sources).
BOOT_ENABLED="yes"
BOOT_PATHS="/boot /boot/efi"

# ---- Destination retention — WYSIWYG GFS, Snapper's TIMELINE_LIMIT_* vocabulary
# =============================================================================
# What you set here is EXACTLY what the destination keeps (grandfather-father-son:
# the newest snapshot of each of the most recent N hours/days/weeks/months/years,
# unioned). The ONE exception: the most recent snapshot is always kept as the next
# incremental's base ("the pinned parent"). A tier set to 0 is disabled.
#
# Remember snappersend sends only Snapper's CURRENT NEWEST snapshot each run, so the
# destination is a sample at snappersend's run cadence — set these to the history
# DEPTH you want to keep on the destination, independent of Snapper's own limits.
RETENTION_TIMEZONE="local"                    # "local" (default) or "utc" bucket boundaries

# Default policy (applies to every subvol unless overridden below):
TIMELINE_LIMIT_HOURLY="24"
TIMELINE_LIMIT_DAILY="14"
TIMELINE_LIMIT_WEEKLY="8"
TIMELINE_LIMIT_MONTHLY="6"
TIMELINE_LIMIT_YEARLY="2"

# Optional per-subvol overrides: prefix a tier with <SUBVOL>_ (uppercased). Only the
# tiers you list are overridden; the rest inherit the default above (an explicit "0"
# disables that tier for that subvol). Example — keep a deeper archive of the OS root:
ROOT_TIMELINE_LIMIT_DAILY="30"
ROOT_TIMELINE_LIMIT_MONTHLY="12"

# Boot-path versions take the same scheme, named by the path's parent-dir name
# uppercased with '-' -> '_' (so /boot -> BOOT_..., /boot/efi -> BOOT_EFI_...).
# Note: a Btrfs subvol literally named "boot" would share the BOOT_ prefix.
#BOOT_TIMELINE_LIMIT_HOURLY="0"
#BOOT_TIMELINE_LIMIT_DAILY="7"
#BOOT_EFI_TIMELINE_LIMIT_DAILY="7"

# ============================================================================
# LOGGING  ([STEP]/[INFO]/[OK]/[WARN]/[ERROR], di-*.sh house style)
# ============================================================================
# Structured logging to a file (default /var/log/snapsend.log, override with
# $SNAPSEND_LOG) plus the terminal (coloured when stderr is a tty). File logging
# is best-effort: if the log path is not writable we degrade to stderr only
# rather than aborting the run. Set $SNAPSEND_QUIET to silence (used by tests).

_VERBOSE = False
_QUIET = bool(os.environ.get("SNAPSEND_QUIET"))
_LOG_PATH = os.environ.get("SNAPSEND_LOG", "/var/log/snapsend.log")
_RESET = "\033[0m"
_LEVEL_COLOR = {
    "STEP":  "\033[1;36m",   # bold cyan
    "INFO":  "\033[0;34m",   # blue
    "OK":    "\033[0;32m",   # green
    "WARN":  "\033[0;33m",   # yellow
    "ERROR": "\033[0;31m",   # red
}
_logfile = None  # None=untried, False=tried-and-failed, else file object


def _open_logfile():
    global _logfile
    if _logfile is not None:
        return _logfile
    try:
        _logfile = open(_LOG_PATH, "a", encoding="utf-8")
    except OSError:
        _logfile = False
    return _logfile


def _emit(level: str, msg: str) -> None:
    if _QUIET:
        return
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    plain = f"{ts} [{level}] {msg}"
    lf = _open_logfile()
    if lf:
        try:
            lf.write(plain + "\n")
            lf.flush()
        except OSError:
            pass
    if sys.stderr.isatty():
        color = _LEVEL_COLOR.get(level, "")
        sys.stderr.write(f"{ts} {color}[{level}]{_RESET} {msg}\n")
    else:
        sys.stderr.write(plain + "\n")


def log_step(m: str) -> None:  _emit("STEP", m)
def log_info(m: str) -> None:  _emit("INFO", m)
def log_ok(m: str) -> None:    _emit("OK", m)
def log_warn(m: str) -> None:  _emit("WARN", m)
def log_error(m: str) -> None: _emit("ERROR", m)


def log_debug(m: str) -> None:
    if _VERBOSE:
        _emit("INFO", m)


def _log(m: str) -> None:
    """Back-compat alias used by the skeleton call sites."""
    _emit("INFO", m)


# ============================================================================
# CONFIG  (loaded from /etc/snapsend/config TOML; CLI flag > env > file)
# ============================================================================

@dataclass(frozen=True)
class Config:
    """
    Populated from /etc/snapsend/config (TOML) at startup — NOT hard-coded.
    Operational flags (--server/--dry-run/--subvol/--no-mbuffer) override via
    three-tier precedence; retention is file-only policy (SPEC §8/§9).
    """
    server_host: str
    server_ssh_port: int = 22
    server_user: str = "snapsend"       # dedicated least-priv transport user
    ssh_key: str = "/etc/snapsend/ssh/id_ed25519"
    # subvol-name -> {"mountpoint": str, "recv_dir": str}
    subvols: dict = field(default_factory=lambda: {
        "home": {"mountpoint": "/home", "recv_dir": "/srv/snapshots-recv/home"},
        "root": {"mountpoint": "/",     "recv_dir": "/srv/snapshots-recv/root"},
    })
    # TARGET-ONLY retention (Decision 1): source is Snapper-owned, never pruned
    # here. Per-subvol policy; falls back to "default". The pinned parent
    # (Rule 3) is always excluded from deletion.
    retention: dict = field(default_factory=lambda: {
        "default": {"keep_daily": 14, "keep_weekly": 8, "keep_monthly": 6},
        "root":    {"keep_daily": 30, "keep_weekly": 12, "keep_monthly": 12},
    })
    use_mbuffer: bool = True
    dry_run: bool = False

    # Non-Btrfs boot tier (EFI=FAT32, /boot=ext4): rsync'd as a single current
    # mirror, NOT versioned, NOT through the snapshot machinery (SPEC §11).
    boot_backup_enabled: bool = True
    boot_paths: tuple = ("/boot", "/boot/efi")   # rsync these (efi nested last)
    boot_recv_base: str = "/srv/snapshots-recv"  # + /<hostname>/{boot,boot-efi}

    def retention_for(self, subvol_name: str) -> dict:
        """Per-subvol retention with fallback to default."""
        return self.retention.get(subvol_name, self.retention["default"])


def load_config(path: str = "/etc/snapsend/config") -> dict:
    """
    Parse the TOML config into kwargs for Config (tomllib, stdlib 3.11+).

    Maps [server], [boot], [subvolumes.*] and [retention.*] tables onto Config
    fields. Only keys present in the file are returned, so Config's own defaults
    fill the rest. A [retention.default] is guaranteed to exist (retention_for
    depends on it). Raises FileNotFoundError if the file is absent, KeyError if a
    required field is missing, and tomllib.TOMLDecodeError on malformed TOML —
    all surfaced cleanly by main().
    """
    import tomllib
    with open(path, "rb") as f:
        data = tomllib.load(f)

    kwargs: dict = {}

    server = data.get("server", {})
    if "host" not in server:
        raise KeyError("[server].host is required in the config")
    kwargs["server_host"] = str(server["host"])
    if "ssh_port" in server:
        kwargs["server_ssh_port"] = int(server["ssh_port"])
    if "user" in server:
        kwargs["server_user"] = str(server["user"])
    if "ssh_key" in server:
        kwargs["ssh_key"] = str(server["ssh_key"])
    if "use_mbuffer" in server:
        kwargs["use_mbuffer"] = bool(server["use_mbuffer"])

    boot = data.get("boot", {})
    if "enabled" in boot:
        kwargs["boot_backup_enabled"] = bool(boot["enabled"])
    if "paths" in boot:
        kwargs["boot_paths"] = tuple(str(p) for p in boot["paths"])
    if "recv_base" in boot:
        kwargs["boot_recv_base"] = str(boot["recv_base"])

    subs = data.get("subvolumes")
    if subs:
        parsed = {}
        for name, t in subs.items():
            parsed[name] = {
                "mountpoint": str(t["mountpoint"]),
                "recv_dir": str(t["recv_dir"]),
            }
        kwargs["subvols"] = parsed

    ret = data.get("retention")
    if ret:
        parsed = {}
        for name, t in ret.items():
            parsed[name] = {
                "keep_daily": int(t.get("keep_daily", 0)),
                "keep_weekly": int(t.get("keep_weekly", 0)),
                "keep_monthly": int(t.get("keep_monthly", 0)),
            }
        parsed.setdefault(
            "default", {"keep_daily": 14, "keep_weekly": 8, "keep_monthly": 6}
        )
        kwargs["retention"] = parsed

    return kwargs


# ============================================================================
# SUBVOLUME IDENTITY  (the fields rules 1-3 depend on)
# ============================================================================

@dataclass
class Subvol:
    """One Btrfs subvolume's identity, parsed from `btrfs subvolume show`."""
    path: str
    uuid: str
    parent_uuid: str            # '-' if none
    received_uuid: str          # '-' if not a received subvol
    readonly: bool
    # Snapper number when this is a snapper snapshot (source), or parsed from the
    # server-side <num>-<short_uuid> dir name (target). None otherwise.
    snapper_num: Optional[int] = None
    snapper_time: Optional[str] = None        # raw info.xml <date> (source only)
    info_time: Optional[datetime] = None      # parsed info.xml date  (source)
    creation_time: Optional[datetime] = None  # parsed `btrfs ... show` Creation
    snapper_type: Optional[str] = None        # 'single'|'pre'|'post' (source)
    pre_num: Optional[int] = None             # paired pre num for a 'post' (src)

    # --- rule (1): is this a cleanly-received target subvol? ---------------
    @property
    def is_valid_received(self) -> bool:
        """A clean receive is readonly AND has received_uuid set."""
        return self.readonly and self.received_uuid != "-"

    @property
    def is_garbled(self) -> bool:
        """Partial/interrupted receive: writable AND no received_uuid."""
        return (not self.readonly) and self.received_uuid == "-"

    @property
    def when(self) -> Optional[datetime]:
        """Best-known timestamp for ordering / retention bucketing.

        Source snapshots prefer their Snapper info.xml date; targets (and any
        snapshot lacking info.xml) fall back to the Btrfs creation time from
        `btrfs subvolume show` (SPEC task 5)."""
        return self.info_time or self.creation_time


# --- rule (2): correlation test (parent eligibility) -----------------------
def is_correlated(a: Subvol, b: Subvol) -> bool:
    """
    True if a and b are the same Btrfs lineage and thus a valid send-parent
    pairing. Both must be readonly. (btrbk _is_correlated, btrfs:2587)

    Every clause guards against '-' (Snapper's "no value", and our parse fallback
    for a missing field) so an unknown UUID never spuriously correlates: '-' means
    "unknown lineage", which must match nothing.
    """
    if not (a.readonly and b.readonly):
        return False
    if a.uuid != "-" and a.uuid == b.received_uuid:
        return True
    if b.uuid != "-" and b.uuid == a.received_uuid:
        return True
    if a.received_uuid != "-" and a.received_uuid == b.received_uuid:
        return True
    return False


# ============================================================================
# SHELL HELPERS
# ============================================================================

def run_local(argv: list[str], *, check: bool = True) -> subprocess.CompletedProcess:
    """Run a local command, capturing output. Missing executables degrade to a
    rc=127 CompletedProcess when check=False (so callers can handle a host that
    lacks btrfs/rsync/ssh without an unhandled traceback)."""
    log_debug("local: " + " ".join(shlex.quote(a) for a in argv))
    try:
        cp = subprocess.run(argv, check=False, capture_output=True, text=True)
    except FileNotFoundError as e:
        if check:
            raise
        return subprocess.CompletedProcess(argv, 127, "", str(e))
    if check and cp.returncode != 0:
        raise subprocess.CalledProcessError(cp.returncode, argv, cp.stdout, cp.stderr)
    return cp


def ssh_argv(cfg: Config, remote_cmd: str) -> list[str]:
    """Build the ssh invocation for a remote command string."""
    return [
        "ssh", "-i", cfg.ssh_key, "-p", str(cfg.server_ssh_port),
        "-o", "BatchMode=yes",
        f"{cfg.server_user}@{cfg.server_host}",
        remote_cmd,
    ]


def run_remote(cfg: Config, remote_cmd: str, *, check: bool = True):
    """Run a command on the server over ssh."""
    return run_local(ssh_argv(cfg, remote_cmd), check=check)


# ============================================================================
# PARSING  `btrfs subvolume show`
# ============================================================================

def _parse_dt(s: Optional[str]) -> Optional[datetime]:
    """Parse a Snapper/Btrfs timestamp into a NAIVE-UTC datetime.

    Handles info.xml's `YYYY-MM-DD HH:MM:SS` (UTC, no zone) and btrfs'
    `YYYY-MM-DD HH:MM:SS +0000`. Returns None for empty/'-'/unparseable input so
    bucketing can fall back gracefully."""
    if not s:
        return None
    txt = s.strip()
    if not txt or txt == "-":
        return None
    for fmt in ("%Y-%m-%d %H:%M:%S %z", "%Y-%m-%d %H:%M:%S"):
        try:
            dt = datetime.strptime(txt, fmt)
            if dt.tzinfo is not None:
                dt = dt.astimezone(timezone.utc).replace(tzinfo=None)
            return dt
        except ValueError:
            continue
    return None


def parse_subvolume_show(text: str, path: str) -> Subvol:
    """
    Parse the human output of `btrfs subvolume show` into a Subvol.

    We need uuid, parent_uuid, received_uuid, the readonly flag, and (for
    retention) the creation time. Field lines look like `Key:\\t\\tvalue`; matching
    is done on a normalised lowercased prefix so trailing-whitespace / tab-count
    differences across btrfs-progs versions don't matter. Missing fields default
    to '-' / False / None. Readonly comes from the `Flags:` line (contains
    'readonly' on RO subvols); show_local/show_remote cross-check via
    `btrfs property get ... ro` when no Flags line is present (SPEC task 4).
    """
    uuid = parent_uuid = received_uuid = "-"
    readonly = False
    creation_time = None

    for line in text.splitlines():
        s = line.strip()
        low = s.lower()
        if low.startswith("received uuid:"):
            received_uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("parent uuid:"):
            parent_uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("uuid:"):
            uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("flags:"):
            readonly = "readonly" in low
        elif low.startswith("creation time:"):
            creation_time = _parse_dt(s.split(":", 1)[1])

    return Subvol(
        path=path,
        uuid=uuid,
        parent_uuid=parent_uuid,
        received_uuid=received_uuid,
        readonly=readonly,
        creation_time=creation_time,
    )


def _ro_property_local(path: str) -> bool:
    cp = run_local(["btrfs", "property", "get", path, "ro"], check=False)
    return "ro=true" in cp.stdout.replace(" ", "").lower()


def _ro_property_remote(cfg: Config, path: str) -> bool:
    cp = run_remote(cfg, f"sudo btrfs property get {shlex.quote(path)} ro", check=False)
    return "ro=true" in cp.stdout.replace(" ", "").lower()


def show_local(path: str) -> Optional[Subvol]:
    cp = run_local(["btrfs", "subvolume", "show", path], check=False)
    if cp.returncode != 0:
        log_warn(f"btrfs subvolume show failed for {path}: {cp.stderr.strip()}")
        return None
    sv = parse_subvolume_show(cp.stdout, path)
    if "flags:" not in cp.stdout.lower():
        sv.readonly = _ro_property_local(path)
    return sv


def show_remote(cfg: Config, path: str) -> Optional[Subvol]:
    cp = run_remote(cfg, f"sudo btrfs subvolume show {shlex.quote(path)}", check=False)
    if cp.returncode != 0:
        return None
    sv = parse_subvolume_show(cp.stdout, path)
    if "flags:" not in cp.stdout.lower():
        sv.readonly = _ro_property_remote(cfg, path)
    return sv


# ============================================================================
# ENUMERATION
# ============================================================================

def _read_info_xml(info_path: str):
    """Best-effort parse of Snapper's info.xml -> (num, date_str, type, pre_num)."""
    try:
        root = ET.parse(info_path).getroot()
        num = root.findtext("num")
        date = root.findtext("date")
        typ = root.findtext("type")
        pre = root.findtext("pre_num")
        return (
            int(num) if num and num.isdigit() else None,
            date.strip() if date else None,
            typ.strip() if typ else None,
            int(pre) if pre and pre.strip().isdigit() else None,
        )
    except Exception as e:  # malformed/absent xml is non-fatal
        log_debug(f"info.xml parse failed for {info_path}: {e}")
        return (None, None, None, None)


def list_snapper_snapshots(mountpoint: str) -> list[Subvol]:
    """
    Read Snapper's snapshots directly from disk:
        <mountpoint>/.snapshots/<N>/snapshot   (the RO subvolume)
        <mountpoint>/.snapshots/<N>/info.xml   (number, date, pre/post type)

    Only readonly snapshots are sendable (rules 1/2), so RW ones are skipped.
    Both root's top-level @snapshots and home's nested @home/.snapshots expose
    <N>/snapshot at their mountpoint, so the read logic is identical (SPEC §2).
    """
    snaps: list[Subvol] = []
    snap_root = os.path.join(mountpoint, ".snapshots")
    if not os.path.isdir(snap_root):
        log_warn(f"no .snapshots under {mountpoint} ({snap_root} absent)")
        return snaps

    for entry in sorted(os.listdir(snap_root), key=_int_or_zero):
        if not entry.isdigit():
            continue
        sub_path = os.path.join(snap_root, entry, "snapshot")
        if not os.path.isdir(sub_path):
            continue
        sv = show_local(sub_path)
        if sv is None:
            continue
        if not sv.readonly:
            log_debug(f"skipping non-readonly snapshot {sub_path}")
            continue
        sv.snapper_num = int(entry)
        info_path = os.path.join(snap_root, entry, "info.xml")
        if os.path.isfile(info_path):
            num, date, typ, pre = _read_info_xml(info_path)
            sv.snapper_time = date
            sv.info_time = _parse_dt(date)
            sv.snapper_type = typ
            sv.pre_num = pre
        snaps.append(sv)
    return snaps


def list_target_snapshots(cfg: Config, recv_dir: str) -> list[Subvol]:
    """List received subvolumes on the server under recv_dir (over ssh).

    Each received snapshot lives in a per-transfer directory `<num>-<short_uuid>`
    holding the subvol at `<num>-<short_uuid>/snapshot` (SPEC §5.2 receive-in-
    place). We read the subvol one level down, but parse the leading `<num>` from
    the DIRECTORY name for within-machine age ordering. The `<base>.latest`
    symlink is skipped."""
    cp = run_remote(cfg, f"sudo ls -1 {shlex.quote(recv_dir)}", check=False)
    out: list[Subvol] = []
    if cp.returncode != 0:
        return out
    for name in cp.stdout.split():
        if name.endswith(".latest"):
            continue
        sv = show_remote(cfg, os.path.join(recv_dir, name, "snapshot"))
        if sv is None:
            continue
        m = re.match(r"^(\d+)-", name)
        if m:
            sv.snapper_num = int(m.group(1))
        out.append(sv)
    return out


def _int_or_zero(s: str) -> int:
    return int(s) if s.isdigit() else 0


# ============================================================================
# PARENT SELECTION  (rule 2)
# ============================================================================

def choose_parent(
    snapshot: Subvol,
    source_snaps: list[Subvol],
    target_snaps: list[Subvol],
) -> Optional[Subvol]:
    """
    Pick the best `-p` parent for `snapshot`: the NEWEST source snapshot that is
    (a) strictly older than `snapshot` and (b) correlated with some snapshot
    already on the target. Returns None -> must do a full send.
    """
    candidates = [
        s for s in source_snaps
        if s.snapper_num is not None
        and snapshot.snapper_num is not None
        and s.snapper_num < snapshot.snapper_num
        and any(is_correlated(s, t) for t in target_snaps)
    ]
    if not candidates:
        return None
    return max(candidates, key=lambda s: s.snapper_num)


# ============================================================================
# TRANSFER  (the send|receive pipe + rule 1 verification)
# ============================================================================

def send_receive(
    cfg: Config,
    snapshot: Subvol,
    recv_dir: str,
    parent: Optional[Subvol],
) -> bool:
    """
    Stream one snapshot to the server, then VERIFY it landed cleanly (rule 1).
    Returns True only on a verified-good receive. On garble (or a pipe error) it
    deletes the partial subvol on the server and returns False, leaving the
    existing chain intact for a clean retry next run.

    Receive strategy (SPEC §5.2): Snapper's subvol is literally named "snapshot",
    so `btrfs receive` always writes a child subvol named `snapshot`. We receive
    directly into the snapshot's FINAL per-transfer directory
    `<recv_dir>/<num>-<short_uuid>/`, so the subvol lands as
    `<recv_dir>/<num>-<short_uuid>/snapshot` and is NEVER moved. (A received
    subvol is read-only with `received_uuid` set — the very correlation key Rule 2
    needs — so it must not be `mv`'d across directories, which falls back to a
    copy that fails on the RO source, nor flipped to RW, which resets
    received_uuid. Receiving in place sidesteps both.)
    """
    send_cmd = ["btrfs", "send"]
    if parent is not None:
        send_cmd += ["-p", parent.path]
    send_cmd += [snapshot.path]

    # Server-side naming (SPEC §4): <snapper_num>-<short_uuid>.
    #   snapper_num: readable, mirrors Snapper's numbering at send time
    #   short_uuid:  first 8 hex of the source uuid; unique on the server even as
    #               laptop numbers churn, and ties the dir name to the corr. key
    short_uuid = snapshot.uuid.split("-")[0] if snapshot.uuid not in ("", "-") else "nouuid"
    num = snapshot.snapper_num if snapshot.snapper_num is not None else 0
    received_name = f"{num}-{short_uuid}"

    final_dir = os.path.join(recv_dir, received_name)
    final_path = os.path.join(final_dir, "snapshot")   # btrfs names it "snapshot"
    recv_remote = f"sudo btrfs receive {shlex.quote(final_dir)}"

    if cfg.dry_run:
        kind = f"-p {parent.path} " if parent else ""
        log_info(f"[dry-run] btrfs send {kind}{snapshot.path} "
                 f"| ssh ... {recv_remote}  ->  {final_path}")
        return True

    # Start from a clean final dir (drop any garbled leftover from a prior crash:
    # a partial receive leaves a detectable subvol here that Rule 1 rejects, so
    # the source still counts as missing and we re-enter with the same name).
    _cleanup_final(cfg, final_dir)
    run_remote(cfg, f"sudo mkdir -p {shlex.quote(final_dir)}", check=False)

    # Run send -> [mbuffer ->] ssh-receive as a connected pipe, capturing every
    # stage's exit code (PIPESTATUS-equivalent).
    pipe_ok = _run_pipe(send_cmd, ssh_argv(cfg, recv_remote), cfg.use_mbuffer)

    # --- rule (1) verification, regardless of the reported pipe status -------
    received_sv = show_remote(cfg, final_path)
    if received_sv is None or received_sv.is_garbled or not received_sv.is_valid_received:
        log_error(f"garbled/incomplete receive in {final_dir} — cleaning up")
        _cleanup_final(cfg, final_dir)
        return False

    if not pipe_ok:
        # Pipe reported failure but the subvol looks valid — be conservative and
        # re-send next run rather than trust a transfer a stage complained about.
        log_warn(f"pipe reported error though received subvol looks valid; "
                 f"discarding {final_dir} and retrying next run")
        _cleanup_final(cfg, final_dir)
        return False

    # Verified clean: just repoint .latest at the (already final) subvol.
    _update_latest_symlink(cfg, recv_dir, received_name)
    log_ok(f"received #{num} -> {received_name}/snapshot")
    return True


def _cleanup_final(cfg: Config, final_dir: str) -> None:
    """Remove a received (or partial) subvol + its per-transfer dir without
    needing `rm -rf` on the server (keeps the transport user's sudoers grant
    tight). Best-effort: deletes <final_dir>/snapshot then rmdir's <final_dir>."""
    subvol = os.path.join(final_dir, "snapshot")
    run_remote(cfg, f"sudo btrfs subvolume delete {shlex.quote(subvol)}", check=False)
    run_remote(cfg, f"sudo rmdir {shlex.quote(final_dir)}", check=False)


def _run_pipe(send_argv, ssh_argv_list, use_mbuffer) -> bool:
    """
    Connect `btrfs send` -> [mbuffer ->] ssh receive and return True iff EVERY
    stage exits 0 (a failure in `btrfs send` must not be masked by a 0 from ssh).

    Implemented with Popen chaining: each stage's stdout feeds the next stage's
    stdin; the parent closes its copy of each pipe end so SIGPIPE propagates if a
    downstream stage dies. Each stage's stderr is captured to a temp file (not a
    pipe) so a chatty stage can never deadlock the data flow, and is logged after
    the transfer — except mbuffer when interactive, which inherits the terminal
    so its live throughput readout is visible during the (big) seed transfer.

    Each stage is (name, argv, capture_stderr).
    """
    stages: list[tuple[str, list[str], bool]] = [("btrfs send", list(send_argv), True)]
    mb = bool(use_mbuffer) and shutil.which("mbuffer") is not None
    if use_mbuffer and not mb:
        log_warn("use_mbuffer set but mbuffer not on PATH; continuing without it")
    if mb:
        if sys.stderr.isatty():
            # Interactive: show the live progress/rate readout on the terminal.
            stages.append(("mbuffer", ["mbuffer", "-m", "256M"], False))
        else:
            # Under systemd (no tty): stay quiet, capture anything for the log.
            stages.append(("mbuffer", ["mbuffer", "-q", "-m", "256M"], True))
    stages.append(("ssh receive", list(ssh_argv_list), True))

    # procs entries: (name, Popen, errf_or_None). errfiles tracks every temp file
    # created, even for a stage whose Popen raises, so cleanup never leaks one.
    procs: list[tuple[str, subprocess.Popen, object]] = []
    errfiles: list = []
    prev_stdout = None
    try:
        for i, (name, argv, capture) in enumerate(stages):
            errf = tempfile.TemporaryFile() if capture else None
            if errf is not None:
                errfiles.append(errf)
            is_last = (i == len(stages) - 1)
            p = subprocess.Popen(
                argv,
                stdin=prev_stdout,
                stdout=(subprocess.DEVNULL if is_last else subprocess.PIPE),
                stderr=errf,            # None -> inherit (live mbuffer progress)
            )
            if prev_stdout is not None:
                prev_stdout.close()     # parent drops its end so SIGPIPE can flow
            procs.append((name, p, errf))
            prev_stdout = p.stdout
    except (FileNotFoundError, OSError) as e:
        log_error(f"failed to start pipe: {e}")
        for _, p, _ef in procs:
            with contextlib.suppress(Exception):
                p.kill()
        for ef in errfiles:
            with contextlib.suppress(Exception):
                ef.close()
        return False

    all_ok = True
    for name, p, errf in procs:
        rc = p.wait()
        err = ""
        if errf is not None:
            try:
                errf.seek(0)
                err = errf.read().decode("utf-8", "replace").strip()
            finally:
                errf.close()
        if rc != 0:
            all_ok = False
            log_error(f"  pipe stage '{name}' exited {rc}" + (f": {err}" if err else ""))
        elif err:
            log_debug(f"  pipe stage '{name}': {err}")
    return all_ok


def _update_latest_symlink(cfg: Config, recv_dir: str, name: str) -> None:
    """
    Maintain <recv_dir>/<subvol>.latest -> newest received SUBVOL, so the
    downstream restic tier has a stable target (our equivalent of btrbk's
    `latest` pointer). `name` is the per-transfer directory `<num>-<short_uuid>`;
    the link points one level down at its `snapshot` subvol — restic backs up the
    subvol's contents, so the target must be the subvol, not the wrapper dir.
    """
    base = os.path.basename(recv_dir.rstrip("/"))
    link = os.path.join(recv_dir, f"{base}.latest")
    target = os.path.join(recv_dir, name, "snapshot")
    run_remote(cfg, f"sudo ln -sfn {shlex.quote(target)} {shlex.quote(link)}", check=False)


# ============================================================================
# BOOT TIER  (non-Btrfs: EFI=FAT32, /boot=ext4 — rsync mirror, not versioned)
# ============================================================================
# /boot and /boot/efi cannot be btrfs-sent (wrong fs, no snapshots). They are
# mirrored to the server with `rsync -aAX --delete` so DR can reconstruct a
# bootable system WITH our custom bootloader config. Single current copy only;
# the downstream restic-on-server tier picks it up from the receive area and
# versions it for free. Feeds the existing di-btrfs-recovery.sh restore flow.

def boot_backup(cfg: Config, hostname: str) -> bool:
    """
    rsync each non-Btrfs boot path to /srv/snapshots-recv/<hostname>/<name>/ on
    the server over SSH. Returns True iff every path synced cleanly. Fail-safe: a
    failure is logged/warned but does not abort the rest of the run (the boot
    tier is independent of the snapshot tiers).

    Mapping (matches the original di-btrbk.sh): /boot -> boot/, /boot/efi -> boot-efi/
    """
    if not cfg.boot_backup_enabled:
        log_info("Boot backup disabled — skipping.")
        return True

    log_step(f"Boot mirror ({', '.join(cfg.boot_paths)} -> "
             f"{cfg.boot_recv_base}/{hostname}/)")

    rsh = f"ssh -i {cfg.ssh_key} -p {cfg.server_ssh_port} -o BatchMode=yes"
    all_ok = True

    for src in cfg.boot_paths:
        if not os.path.ismount(src) and not os.path.isdir(src):
            log_warn(f"  boot path {src} not present — skipping")
            continue
        # /boot -> "boot", /boot/efi -> "boot-efi"  (stable, collision-free)
        name = src.strip("/").replace("/", "-")
        dest = f"{cfg.boot_recv_base}/{hostname}/{name}"

        # rsync won't mkdir -p the remote parent chain; ensure it exists.
        run_remote(cfg, f"sudo mkdir -p {shlex.quote(dest)}", check=False)

        # Trailing slashes are load-bearing: "<src>/" copies contents into
        # "<dest>/". -aAX preserves perms/ACLs/xattrs; --delete makes it a true
        # mirror; rsync runs under sudo remotely so it can write the receive area.
        rsync_argv = [
            "rsync", "-aAX", "--delete",
            "-e", rsh,
            "--rsync-path", "sudo rsync",
            f"{src.rstrip('/')}/",
            f"{cfg.server_user}@{cfg.server_host}:{dest}/",
        ]

        if cfg.dry_run:
            log_info(f"[dry-run] rsync {src}/ -> {dest}/")
            continue

        cp = run_local(rsync_argv, check=False)
        # EFI (FAT32) has no perms/ownership/ACLs/xattrs, so -aAX emits benign
        # warnings on the efi path. Treat rc 0 and 24 (vanished source files) as
        # success; warn (don't fail the run) otherwise.
        if cp.returncode in (0, 24):
            log_ok(f"  {src} mirrored to {dest}")
        else:
            log_warn(f"  rsync of {src} failed (rc={cp.returncode}) — continuing; "
                     "boot tier is independent of the snapshot tiers"
                     + (f": {cp.stderr.strip()}" if cp.stderr.strip() else ""))
            all_ok = False

    return all_ok


# ============================================================================
# RETENTION  (rule 3 — never prune the pinned newest correlated pair)
# ============================================================================

def _bucket_keep(targets_newest_first: list[Subvol],
                 keep_daily: int, keep_weekly: int, keep_monthly: int) -> set:
    """
    GFS (grandfather-father-son) keep-set over already-newest-first targets.
    Returns the set of target.path to KEEP: the newest snapshot of each of the
    most recent `keep_daily` days, `keep_weekly` ISO-weeks, and `keep_monthly`
    months (union). Undatable targets are kept (we never delete what we can't
    place). Same semantics as btrbk/borg/restic prune.
    """
    keep: set = set()
    last = {"d": None, "w": None, "m": None}
    cnt = {"d": 0, "w": 0, "m": 0}
    lim = {"d": keep_daily, "w": keep_weekly, "m": keep_monthly}

    for t in targets_newest_first:
        w = t.when
        if w is None:
            keep.add(t.path)
            continue
        iso = w.isocalendar()
        keys = {
            "d": (w.year, w.month, w.day),
            "w": (iso[0], iso[1]),
            "m": (w.year, w.month),
        }
        for p in ("d", "w", "m"):
            if lim[p] > 0 and keys[p] != last[p] and cnt[p] < lim[p]:
                keep.add(t.path)
                last[p] = keys[p]
                cnt[p] += 1
    return keep


def _keep_prepost_partners(keep_paths: set,
                           source_snaps: list[Subvol],
                           target_snaps: list[Subvol]) -> set:
    """
    Root-only nicety (SPEC §4): avoid orphaning half an apt pre/post pair. For
    every kept target, if its correlated source is a 'post' (or 'pre'), also keep
    the target correlated with its partner. Best-effort — silently does nothing
    when the source side has already been pruned by Snapper. Returns extra paths.
    """
    extra: set = set()

    def corr_source(t: Subvol) -> Optional[Subvol]:
        for s in source_snaps:
            if is_correlated(s, t):
                return s
        return None

    tgt_by_src_num: dict = {}
    src_of_tgt: dict = {}
    for t in target_snaps:
        s = corr_source(t)
        if s and s.snapper_num is not None:
            tgt_by_src_num[s.snapper_num] = t
            src_of_tgt[t.path] = s

    for t in target_snaps:
        if t.path not in keep_paths:
            continue
        s = src_of_tgt.get(t.path)
        if not s:
            continue
        if s.snapper_type == "post" and s.pre_num is not None:
            partner = tgt_by_src_num.get(s.pre_num)
            if partner:
                extra.add(partner.path)
        elif s.snapper_type == "pre" and s.snapper_num is not None:
            for s2 in source_snaps:
                if s2.snapper_type == "post" and s2.pre_num == s.snapper_num:
                    partner = tgt_by_src_num.get(s2.snapper_num)
                    if partner:
                        extra.add(partner.path)
    return extra


def apply_retention(
    cfg: Config,
    subvol_name: str,
    source_snaps: list[Subvol],
    target_snaps: list[Subvol],
    recv_dir: str,
) -> None:
    """
    Prune the TARGET ONLY (Decision 1) per the per-subvol policy from config.
    Source snapshots are NEVER pruned here — Snapper owns local retention.

    SUPERSET MODEL (Option B): the server is a superset of the source. A target is
    pruned only if it is BOTH outside the GFS keep set AND its source counterpart
    is already gone. While the laptop still holds a snapshot, the server keeps its
    copy — so GFS thinning applies only to the "long tail" of source-deleted
    snapshots. This eliminates re-send/re-prune churn by construction: the
    snapshots replicate_subvol would re-send (still on source, missing on target)
    are exactly the ones protected from pruning here.

    PIN the newest correlated pair so the next incremental's parent survives
    (Rule 3), keep the GFS daily/weekly/monthly set, keep every target whose
    source still exists, and (for root) keep pre/post pairs together. Everything
    else on the target (the GFS-thinned long tail) is deleted.
    """
    policy = cfg.retention_for(subvol_name)
    kd = int(policy.get("keep_daily", 0))
    kw = int(policy.get("keep_weekly", 0))
    km = int(policy.get("keep_monthly", 0))

    _pinned_source, pinned_target = _newest_correlated_pair(source_snaps, target_snaps)
    log_step(f"[{subvol_name}] retention keep_daily={kd} keep_weekly={kw} "
             f"keep_monthly={km}; pinned target="
             f"{os.path.basename(pinned_target.path) if pinned_target else None}")

    if not target_snaps:
        return

    targets_sorted = sorted(
        target_snaps, key=lambda t: (t.when or datetime.min), reverse=True
    )
    keep_paths = _bucket_keep(targets_sorted, kd, kw, km)

    # Rule 3: the pinned parent is never pruned, whatever the policy says.
    if pinned_target is not None:
        keep_paths.add(pinned_target.path)

    if subvol_name == "root":
        keep_paths |= _keep_prepost_partners(keep_paths, source_snaps, target_snaps)

    # Option B: never prune a target whose SOURCE snapshot still exists. While the
    # laptop holds a snapshot, the server keeps its copy (the server is a superset
    # of the source). GFS thinning applies only to the long tail — targets whose
    # source has already aged out. This prevents re-send/re-prune churn, because
    # the snapshots replicate_subvol would re-send are exactly these still-on-
    # source ones, now protected. Applied AFTER the GFS/pin/pre-post keep set so it
    # only ever widens it.
    source_backed = {
        t.path
        for t in target_snaps
        if any(is_correlated(s, t) for s in source_snaps)
    }
    keep_paths |= source_backed

    to_delete = [t for t in target_snaps if t.path not in keep_paths]
    log_info(f"[{subvol_name}] retention: {len(source_backed)} target(s) kept "
             f"(source still present), {len(to_delete)} long-tail pruned.")
    if not to_delete:
        return

    for t in to_delete:
        # t.path is the subvol `<recv_dir>/<num>-<short_uuid>/snapshot`; delete the
        # subvol, then rmdir its now-empty per-transfer wrapper directory.
        wrapper_dir = os.path.dirname(t.path)
        if cfg.dry_run:
            log_info(f"[dry-run] would prune {wrapper_dir}")
            continue
        cp = run_remote(cfg, f"sudo btrfs subvolume delete {shlex.quote(t.path)}",
                        check=False)
        if cp.returncode == 0:
            run_remote(cfg, f"sudo rmdir {shlex.quote(wrapper_dir)}", check=False)
            log_info(f"  pruned {os.path.basename(wrapper_dir)}")
        else:
            log_warn(f"  failed to prune {t.path}: {cp.stderr.strip()}")

    # Keep .latest pointing at the newest surviving target's wrapper dir
    # (_update_latest_symlink appends /snapshot).
    if not cfg.dry_run:
        survivors = [t for t in target_snaps if t.path in keep_paths]
        if survivors:
            newest = max(survivors, key=lambda t: (t.when or datetime.min))
            _update_latest_symlink(cfg, recv_dir, os.path.basename(os.path.dirname(newest.path)))


def _newest_correlated_pair(
    source_snaps: list[Subvol],
    target_snaps: list[Subvol],
) -> tuple[Optional[Subvol], Optional[Subvol]]:
    """Find the newest (source, target) pair that is correlated — the parent the
    next incremental will use. This pair is never pruned (Rule 3)."""
    best: tuple[Optional[Subvol], Optional[Subvol]] = (None, None)
    best_num = -1
    for s in source_snaps:
        for t in target_snaps:
            if is_correlated(s, t) and (s.snapper_num or -1) > best_num:
                best_num = s.snapper_num or -1
                best = (s, t)
    return best


# ============================================================================
# MAIN PER-SUBVOL FLOW
# ============================================================================

def replicate_subvol(cfg: Config, name: str, mountpoint: str, recv_dir: str) -> bool:
    """Full flow for one subvol: enumerate -> diff -> send missing -> retention."""
    log_step(f"Replicating '{name}' ({mountpoint} -> {recv_dir})")

    # Enumerate the local source first; if there's nothing to replicate we skip
    # the network entirely (no point ssh-ing just to mkdir an unused recv dir).
    source_snaps = list_snapper_snapshots(mountpoint)
    if not source_snaps:
        log_info(f"No snapper snapshots under {mountpoint}/.snapshots — nothing to do.")
        return True

    run_remote(cfg, f"sudo mkdir -p {shlex.quote(recv_dir)}", check=False)
    target_snaps = list_target_snapshots(cfg, recv_dir)

    # Which source snapshots are not yet on the target (by correlation)?
    missing = [
        s for s in source_snaps
        if not any(is_correlated(s, t) for t in target_snaps)
    ]
    # Send oldest-missing-first so each can parent the next.
    missing.sort(key=lambda s: s.snapper_num or 0)
    log_info(f"[{name}] {len(source_snaps)} source / {len(target_snaps)} target "
             f"snapshots; {len(missing)} to send.")

    ok = True
    for snap in missing:
        parent = choose_parent(snap, source_snaps, target_snaps)
        kind = "incremental" if parent else "FULL"
        log_info(f"  sending #{snap.snapper_num} ({kind}"
                 + (f", parent #{parent.snapper_num}" if parent else "") + ")")
        if not send_receive(cfg, snap, recv_dir, parent):
            log_error(f"  STOP: transfer failed at #{snap.snapper_num}; "
                      "leaving chain intact for retry.")
            ok = False
            break
        # Refresh target view so the next iteration sees the new parent. In a dry
        # run nothing actually landed, so skip the redundant remote round-trip.
        if not cfg.dry_run:
            target_snaps = list_target_snapshots(cfg, recv_dir)

    if ok:
        apply_retention(cfg, name, source_snaps, target_snaps, recv_dir)
    return ok


# ============================================================================
# RUN LOCK  (so two runs can't overlap — cheap insurance, btrbk does this too)
# ============================================================================

class _AlreadyRunning(Exception):
    pass


@contextlib.contextmanager
def run_lock(path: Optional[str] = None):
    """flock a lockfile for the whole run. If another run holds it, raise
    _AlreadyRunning (main exits cleanly). If the lockfile can't even be opened
    (e.g. unprivileged dev run), warn and proceed lock-less rather than abort."""
    path = path or os.environ.get("SNAPSEND_LOCK", "/var/lock/snapsend.lock")
    try:
        f = open(path, "w")
    except OSError as e:
        log_warn(f"could not open lockfile {path} ({e}); proceeding without lock")
        yield
        return
    try:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        f.close()
        log_error(f"another di-snapsend run holds {path}; exiting")
        raise _AlreadyRunning()
    try:
        yield
    finally:
        with contextlib.suppress(Exception):
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)
        f.close()


def _write_success_stamp() -> None:
    """Touch a stamp the watchdog reads to detect missed/failed runs."""
    stamp = os.environ.get("SNAPSEND_STAMP", "/var/lib/snapsend/last-success")
    try:
        os.makedirs(os.path.dirname(stamp), exist_ok=True)
        with open(stamp, "w") as f:
            f.write(datetime.now().strftime("%Y-%m-%d %H:%M:%S\n"))
    except OSError as e:
        log_debug(f"could not write success stamp {stamp}: {e}")


# ============================================================================
# CLI
# ============================================================================

def _truthy(v: Optional[str]) -> bool:
    return v not in (None, "", "0", "false", "False", "no", "off")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="di-snapsend",
        description="Snapper-native Btrfs snapshot replication to a server over SSH.",
    )
    p.add_argument("--config",
                   default=os.environ.get("SNAPSEND_CONFIG", "/etc/snapsend/config"),
                   help="config file (default /etc/snapsend/config, $SNAPSEND_CONFIG)")
    p.add_argument("--server", default=None,
                   help="override the server host from config ($SNAPSEND_SERVER)")
    p.add_argument("--subvol", default=None,
                   help="replicate only this subvolume (name from config)")
    p.add_argument("--dry-run", dest="dry_run", action="store_true", default=None,
                   help="log what would happen; change nothing ($SNAPSEND_DRY_RUN)")
    p.add_argument("--skip-boot", action="store_true",
                   help="skip the non-Btrfs /boot + /boot/efi rsync tier")
    p.add_argument("--no-mbuffer", action="store_true",
                   help="do not pipe through mbuffer even if configured")
    p.add_argument("-v", "--verbose", action="store_true",
                   help="log every shell command and extra detail")
    return p


def main(argv: list[str]) -> int:
    args = build_parser().parse_args(argv)

    global _VERBOSE
    _VERBOSE = args.verbose

    # Load policy from the config file, then apply three-tier overrides
    # (CLI flag > env var > config-file value) for operational settings.
    try:
        kwargs = load_config(args.config)
    except FileNotFoundError:
        log_error(f"config not found: {args.config} "
                  "(run di-snapsend.sh --laptop to create it)")
        return 2
    except Exception as e:  # KeyError / ValueError / TOMLDecodeError
        log_error(f"invalid config {args.config}: {e}")
        return 2

    server = args.server or os.environ.get("SNAPSEND_SERVER")
    if server:
        kwargs["server_host"] = server

    if args.dry_run is not None:
        kwargs["dry_run"] = True
    elif "SNAPSEND_DRY_RUN" in os.environ:
        kwargs["dry_run"] = _truthy(os.environ.get("SNAPSEND_DRY_RUN"))

    if args.no_mbuffer:
        kwargs["use_mbuffer"] = False

    try:
        cfg = Config(**kwargs)
    except TypeError as e:
        log_error(f"config produced invalid settings: {e}")
        return 2

    if args.subvol and args.subvol not in cfg.subvols:
        log_error(f"--subvol {args.subvol!r} not in config subvols "
                  f"{list(cfg.subvols)}")
        return 2

    try:
        with run_lock():
            return _run(cfg, args)
    except _AlreadyRunning:
        return 1


def _run(cfg: Config, args: argparse.Namespace) -> int:
    hostname = socket.gethostname()
    log_step(f"di-snapsend on {hostname} -> {cfg.server_user}@{cfg.server_host}"
             + (" [DRY-RUN]" if cfg.dry_run else ""))

    snapshots_ok = True
    for name, sv in cfg.subvols.items():
        if args.subvol and name != args.subvol:
            continue
        try:
            ok = replicate_subvol(cfg, name, sv["mountpoint"], sv["recv_dir"])
        except Exception as e:
            log_error(f"[{name}] unexpected error: {e}")
            ok = False
        snapshots_ok = snapshots_ok and ok

    boot_ok = True
    if not args.skip_boot:
        try:
            boot_ok = boot_backup(cfg, hostname)
        except Exception as e:
            log_error(f"boot backup error: {e}")
            boot_ok = False

    if snapshots_ok and boot_ok:
        if not cfg.dry_run:
            _write_success_stamp()
        log_ok("di-snapsend finished: all tiers OK")
        return 0

    log_warn("di-snapsend finished with failures "
             f"(snapshots_ok={snapshots_ok} boot_ok={boot_ok}) — see log")
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

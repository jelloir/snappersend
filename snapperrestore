def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="snapperrestore",
        description="Bare-metal disaster recovery from a snappersend "
                    "destination's received snapshot tree (run from a live ISO).",
    )
    p.add_argument("--plan", action="store_true",
                   help="read-only rehearsal: connect, discover, fetch the "
                        "templates and print the derived plan; performs zero "
                        "writes")
    p.add_argument("--disk",
                   help="target disk to WIPE and rebuild (e.g. /dev/nvme0n1; "
                        "prompted with lsblk if omitted)")
    p.add_argument("--source-host",
                   help="hostname directory under RECV_BASE to restore "
                        "(default: the only one, else prompted)")
    p.add_argument("--snapshot",
                   help="snapshot label / epoch prefix to restore (default: "
                        "the newest epoch-matched set)")
    p.add_argument("--server", help="destination server host (overrides config)")
    p.add_argument("--port", type=int, help="destination SSH port")
    p.add_argument("--user", help="transport user (default snappersend)")
    p.add_argument("--ssh-key", dest="ssh_key",
                   help="transport private key (your offline copy after a "
                        "total loss; default /etc/snappersend/ssh/id_ed25519)")
    p.add_argument("--recv-base", dest="recv_base",
                   help="receive base on the server (default /srv/snapshots-recv)")
    p.add_argument("--esp-size", default="512MiB",
                   help="ESP partition size (default 512MiB)")
    p.add_argument("--boot-size", default="2GiB",
                   help="/boot partition size (default 2GiB)")
    p.add_argument("--swap-size", default="2g",
                   help="swapfile size (default 2g)")
    p.add_argument("--no-mbuffer", action="store_true",
                   help="do not pipe the receive through mbuffer")
    p.add_argument("--config",
                   default=os.environ.get("SNAPPERSEND_CONFIG",
                                          "/etc/snappersend/config"),
                   help="snappersend config for transport defaults (default "
                        "/etc/snappersend/config; absent on a live ISO is fine)")
    p.add_argument("-v", "--verbose", action="store_true", default=False,
                   help="log every shell command and extra detail")
    return p


def main(argv: list[str]) -> int:
    args = build_parser().parse_args(argv)
    global _VERBOSE
    _VERBOSE = getattr(args, "verbose", False)
    return cmd_restore(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

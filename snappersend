# ============================================================================
# LOGGING  ([STEP]/[INFO]/[OK]/[WARN]/[ERROR], di-* house style — reused verbatim)
# ============================================================================
# Structured logging to a file (default /var/log/snappersend.log, override with
# $SNAPPERSEND_LOG) plus the terminal (coloured when stderr is a tty). File logging
# is best-effort: an unwritable log path degrades to stderr only rather than
# aborting. Set $SNAPPERSEND_QUIET to silence (used by tests).

_VERBOSE = False
_QUIET = bool(os.environ.get("SNAPPERSEND_QUIET"))
_LOG_PATH = os.environ.get("SNAPPERSEND_LOG", "/var/log/snappersend.log")
_RESET = "\033[0m"
_LEVEL_COLOR = {
    "STEP":  "\033[1;36m",   # bold cyan
    "INFO":  "\033[0;34m",   # blue
    "OK":    "\033[0;32m",   # green
    "WARN":  "\033[0;33m",   # yellow
    "ERROR": "\033[0;31m",   # red
}
_logfile = None  # None=untried, False=tried-and-failed, else file object


def _open_logfile():
    global _logfile
    if _logfile is not None:
        return _logfile
    try:
        _logfile = open(_LOG_PATH, "a", encoding="utf-8")
    except OSError:
        _logfile = False
    return _logfile


def _emit(level: str, msg: str) -> None:
    if _QUIET:
        return
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    plain = f"{ts} [{level}] {msg}"
    lf = _open_logfile()
    if lf:
        try:
            lf.write(plain + "\n")
            lf.flush()
        except OSError:
            pass
    if sys.stderr.isatty():
        color = _LEVEL_COLOR.get(level, "")
        sys.stderr.write(f"{ts} {color}[{level}]{_RESET} {msg}\n")
    else:
        sys.stderr.write(plain + "\n")


def log_step(m: str) -> None:  _emit("STEP", m)
def log_info(m: str) -> None:  _emit("INFO", m)
def log_ok(m: str) -> None:    _emit("OK", m)
def log_warn(m: str) -> None:  _emit("WARN", m)
def log_error(m: str) -> None: _emit("ERROR", m)


def log_debug(m: str) -> None:
    if _VERBOSE:
        _emit("INFO", m)


# ============================================================================
# SUBVOLUME IDENTITY  (the fields the correctness rules depend on)
# ============================================================================

@dataclass
class Subvol:
    """One Btrfs subvolume's identity, parsed from `btrfs subvolume show`."""
    path: str
    uuid: str
    parent_uuid: str            # '-' if none
    received_uuid: str          # '-' if not a received subvol
    readonly: bool
    # Snapper number: for a source snapshot, Snapper's own number; for a parent
    # clone or a received target, parsed back from the <...>-<num>-<...> name so
    # ordering/naming reflect the ORIGINAL snapshot's identity, not the clone's.
    snapper_num: Optional[int] = None
    snapper_time: Optional[str] = None        # raw info.xml <date> (source only)
    info_time: Optional[datetime] = None      # parsed snapshot date (authoritative)
    creation_time: Optional[datetime] = None  # parsed `btrfs ... show` Creation
    snapper_type: Optional[str] = None        # 'single'|'pre'|'post' (source)
    pre_num: Optional[int] = None             # paired pre num for a 'post' (src)

    # --- rule (1): is this a cleanly-received target subvol? ---------------
    @property
    def is_valid_received(self) -> bool:
        """A clean receive is readonly AND has received_uuid set."""
        return self.readonly and self.received_uuid != "-"

    @property
    def is_garbled(self) -> bool:
        """Partial/interrupted receive: writable AND no received_uuid."""
        return (not self.readonly) and self.received_uuid == "-"

    @property
    def when(self) -> Optional[datetime]:
        """Best-known timestamp for ordering / retention bucketing. Prefers the
        snapshot's own info.xml/name date; falls back to the Btrfs creation time."""
        return self.info_time or self.creation_time


# --- rule (2): correlation test (parent eligibility) -----------------------
def is_correlated(a: Subvol, b: Subvol) -> bool:
    """
    True if a and b are the same Btrfs lineage and thus a valid send-parent
    pairing. Both must be readonly. Every clause guards against '-' (Snapper's "no
    value" and our parse fallback) so an unknown UUID never spuriously correlates.
    (btrbk _is_correlated.)
    """
    if not (a.readonly and b.readonly):
        return False
    if a.uuid != "-" and a.uuid == b.received_uuid:
        return True
    if b.uuid != "-" and b.uuid == a.received_uuid:
        return True
    if a.received_uuid != "-" and a.received_uuid == b.received_uuid:
        return True
    return False


# ============================================================================
# CONFIG  (Snapper-schema-aligned, flat KEY="value" — parsed by python-dotenv)
# ============================================================================
# The retention block mirrors Snapper's own config: a flat KEY="value" file using
# Snapper's TIMELINE_LIMIT_* names (incl. YEARLY), so a Snapper user reads it and
# immediately understands it. Transport/layout keys live in the same flat file.
#
# WHY python-dotenv (python3-dotenv, Trixie main) and not configobj/configparser:
#   * configparser (stdlib) requires a [section] header that Snapper files lack;
#     synthesising one is a hack.
#   * configobj parses flat files but RAISES on a duplicate key — a sharp edge
#     against the goal of tolerantly reading a Snapper-shaped file.
#   * python-dotenv is purpose-built for exactly KEY="value": it strips inline
#     comments, tolerates spaces around '=', quoted values with spaces, empties,
#     and malformed/duplicate lines (best-effort, never raises) — so a user can
#     literally point snappersend at a Snapper config and the keys it doesn't use
#     are ignored gracefully. Verified against the real /etc/snapper/configs/root.

# Snapper-only keys snappersend deliberately IGNORES (documented; never an error):
_SNAPPER_IGNORED_KEYS = (
    "SUBVOLUME", "FSTYPE", "QGROUP", "SPACE_LIMIT", "FREE_LIMIT", "ALLOW_USERS",
    "ALLOW_GROUPS", "SYNC_ACL", "BACKGROUND_COMPARISON", "NUMBER_CLEANUP",
    "NUMBER_MIN_AGE", "NUMBER_LIMIT", "NUMBER_LIMIT_IMPORTANT", "TIMELINE_CREATE",
    "TIMELINE_CLEANUP", "TIMELINE_MIN_AGE", "EMPTY_PRE_POST_CLEANUP",
    "EMPTY_PRE_POST_MIN_AGE",
)

# Snapper TIMELINE_LIMIT_* tier -> snappersend GFS keep field.
_TIER_KEYS = (
    ("TIMELINE_LIMIT_HOURLY",  "keep_hourly"),
    ("TIMELINE_LIMIT_DAILY",   "keep_daily"),
    ("TIMELINE_LIMIT_WEEKLY",  "keep_weekly"),
    ("TIMELINE_LIMIT_MONTHLY", "keep_monthly"),
    ("TIMELINE_LIMIT_YEARLY",  "keep_yearly"),
)


@dataclass(frozen=True)
class Config:
    """Populated from the flat config file at startup. Operational flags
    (--dry-run, --subvol, --no-mbuffer, --server) override at the CLI/env layer."""
    server_host: str
    server_ssh_port: int = 22
    server_user: str = "snappersend"    # dedicated least-priv transport user
    ssh_key: str = "/etc/snappersend/ssh/id_ed25519"
    recv_base: str = "/srv/snapshots-recv"
    # subvol-name -> {"mountpoint": str}. recv_dir is composed at runtime as
    # <recv_base>/<hostname>/<name> so multiple machines share one destination.
    subvols: dict = field(default_factory=lambda: {
        "root": {"mountpoint": "/"},
        "home": {"mountpoint": "/home"},
    })
    # Pure-GFS destination retention, Snapper's full tier set (incl. yearly).
    # keep == 0 disables a tier. The pinned parent is the one documented exception.
    retention: dict = field(default_factory=lambda: {
        "default": {"keep_hourly": 24, "keep_daily": 14, "keep_weekly": 8,
                    "keep_monthly": 6, "keep_yearly": 2},
    })
    retention_timezone: str = "local"   # "local" (default) | "utc" bucket boundaries
    use_mbuffer: bool = True
    dry_run: bool = False

    # Parent-preservation tree (the new mechanism).
    parent_tree_base: str = "/.snappersend"
    parent_keep: int = 2                # live parent + one slot of redundancy

    # Non-Btrfs boot tier (EFI=FAT32, /boot=ext4): rsync'd as a single current
    # mirror, not versioned, not through the snapshot machinery.
    boot_backup_enabled: bool = True
    boot_paths: tuple = ("/boot", "/boot/efi")

    def retention_for(self, subvol_name: str) -> dict:
        return self.retention.get(subvol_name, self.retention["default"])

    def recv_dir_for(self, host: str, subvol_name: str) -> str:
        return os.path.join(self.recv_base, host, subvol_name)

    def parent_dir_for(self, subvol_name: str) -> str:
        return os.path.join(self.parent_tree_base, subvol_name)


def _parse_tiers(d: dict, prefix: str = "") -> dict:
    """Pull TIMELINE_LIMIT_* (optionally <PREFIX>_TIMELINE_LIMIT_*) into a keep
    dict. Missing/blank/non-numeric -> 0 (tier disabled) — never raises, so a
    partial or Snapper-shaped file degrades gracefully."""
    keep = {}
    for snap_key, gfs_key in _TIER_KEYS:
        raw = d.get(f"{prefix}{snap_key}" if prefix else snap_key)
        try:
            keep[gfs_key] = int(str(raw).strip()) if raw not in (None, "") else 0
        except (TypeError, ValueError):
            log_warn(f"config: {prefix}{snap_key}={raw!r} is not an integer; "
                     "treating tier as disabled (0)")
            keep[gfs_key] = 0
    return keep


def load_config(path: str = "/etc/snappersend/config") -> dict:
    """
    Parse the flat KEY="value" config into kwargs for Config (python-dotenv).

    Retention uses Snapper's vocabulary: a bare TIMELINE_LIMIT_* set is the default
    policy for every subvol; an optional `<SUBVOL>_TIMELINE_LIMIT_*` (e.g.
    ROOT_TIMELINE_LIMIT_DAILY) overrides one tier for one subvol. Snapper-only keys
    present in the file are ignored without error. Raises FileNotFoundError if the
    file is absent and KeyError only if SERVER_HOST (the one required key) is missing.
    """
    from dotenv import dotenv_values

    if not os.path.isfile(path):
        raise FileNotFoundError(path)
    d = dotenv_values(path)

    def s(key, default=None):
        v = d.get(key)
        return v if v not in (None, "") else default

    def b(key, default):
        v = s(key)
        if v is None:
            return default
        return str(v).strip().lower() in ("1", "true", "yes", "on")

    kwargs: dict = {}

    host = s("SERVER_HOST")
    if not host:
        raise KeyError("SERVER_HOST is required in the config")
    kwargs["server_host"] = host
    if s("SSH_PORT"):
        kwargs["server_ssh_port"] = int(s("SSH_PORT"))
    if s("SERVER_USER"):
        kwargs["server_user"] = s("SERVER_USER")
    if s("SSH_KEY"):
        kwargs["ssh_key"] = s("SSH_KEY")
    if s("RECV_BASE"):
        kwargs["recv_base"] = s("RECV_BASE")
    kwargs["use_mbuffer"] = b("USE_MBUFFER", True)

    # Boot tier
    kwargs["boot_backup_enabled"] = b("BOOT_ENABLED", True)
    if s("BOOT_PATHS"):
        kwargs["boot_paths"] = tuple(s("BOOT_PATHS").split())

    # Parent tree
    if s("PARENT_TREE_BASE"):
        kwargs["parent_tree_base"] = s("PARENT_TREE_BASE")
    if s("PARENT_KEEP"):
        with contextlib.suppress(ValueError):
            kwargs["parent_keep"] = max(1, int(s("PARENT_KEEP")))

    # Retention timezone
    tz = (s("RETENTION_TIMEZONE", "local") or "local").strip().lower()
    if tz not in ("local", "utc"):
        log_warn(f"RETENTION_TIMEZONE {tz!r} unrecognized (expected 'local'/'utc'); "
                 "using 'local'")
        tz = "local"
    kwargs["retention_timezone"] = tz

    # Subvolumes: "root:/ home:/home"  (name:mountpoint pairs)
    if s("SUBVOLUMES"):
        subvols = {}
        for token in s("SUBVOLUMES").split():
            if ":" not in token:
                log_warn(f"config: SUBVOLUMES token {token!r} is not name:mountpoint; "
                         "skipping")
                continue
            name, mnt = token.split(":", 1)
            subvols[name] = {"mountpoint": mnt}
        if subvols:
            kwargs["subvols"] = subvols

    # Retention: default tiers from the bare TIMELINE_LIMIT_*, per-subvol overrides
    # from <SUBVOL>_TIMELINE_LIMIT_*. Composed onto the default so a subvol that
    # overrides only one tier inherits the rest.
    default_keep = _parse_tiers(d)
    # If the file carried no TIMELINE_LIMIT_* at all, fall back to the example/
    # new-install defaults rather than an all-zero (all-disabled) policy.
    if not any(default_keep.values()):
        default_keep = {"keep_hourly": 24, "keep_daily": 14, "keep_weekly": 8,
                        "keep_monthly": 6, "keep_yearly": 2}
    retention = {"default": default_keep}
    names = list(kwargs.get("subvols", {"root": 0, "home": 0}).keys())
    for name in names:
        override = _parse_tiers(d, prefix=f"{name.upper()}_")
        if any(v != 0 for v in override.values()):
            merged = dict(default_keep)
            # Only non-zero override tiers replace the default; a tier the user
            # didn't mention for this subvol keeps the default value.
            raw = {gk: d.get(f"{name.upper()}_{sk}")
                   for sk, gk in _TIER_KEYS}
            for gk, val in override.items():
                if raw[gk] not in (None, ""):
                    merged[gk] = val
            retention[name] = merged
    kwargs["retention"] = retention

    return kwargs


# ============================================================================
# SHELL HELPERS
# ============================================================================

def run_local(argv: list[str], *, check: bool = True) -> subprocess.CompletedProcess:
    """Run a local command, capturing output. Missing executables degrade to a
    rc=127 CompletedProcess when check=False."""
    log_debug("local: " + " ".join(shlex.quote(a) for a in argv))
    try:
        cp = subprocess.run(argv, check=False, capture_output=True, text=True)
    except FileNotFoundError as e:
        if check:
            raise
        return subprocess.CompletedProcess(argv, 127, "", str(e))
    if check and cp.returncode != 0:
        raise subprocess.CalledProcessError(cp.returncode, argv, cp.stdout, cp.stderr)
    return cp


def ssh_argv(cfg: Config, remote_cmd: str) -> list[str]:
    return [
        "ssh", "-i", cfg.ssh_key, "-p", str(cfg.server_ssh_port),
        "-o", "BatchMode=yes",
        f"{cfg.server_user}@{cfg.server_host}",
        remote_cmd,
    ]


def run_remote(cfg: Config, remote_cmd: str, *, check: bool = True):
    return run_local(ssh_argv(cfg, remote_cmd), check=check)


class RemoteUnreachable(Exception):
    """The destination could not be contacted at all (ssh transport failure —
    name resolution, connection refused/timeout, auth). This is DISTINCT from a
    reachable-but-empty destination: on a transport failure we must NOT conclude
    'divergence' and must NOT touch the parent tree (staging/re-cloning the newest
    snapshot would delete a still-correlating confirmed clone via its deterministic
    label, so a transient network blip would force a full send next run — the exact
    thing snappersend exists to avoid). The caller aborts the subvol and retries."""


def _is_ssh_transport_failure(cp: subprocess.CompletedProcess) -> bool:
    """True when a run_remote result reflects ssh's own failure to establish the
    session rather than the remote command's exit status. ssh reserves rc 255 for
    connection/resolution/auth errors; the remote `ls` we run otherwise returns
    0 (ok, possibly empty) or a small code like 2 (missing dir) which we treat as
    'no snapshots yet'. rc 127 is our own 'ssh binary missing' sentinel."""
    if cp.returncode in (255, 127):
        return True
    # Belt-and-suspenders: ssh prefixes its transport diagnostics with "ssh:".
    return any(ln.strip().lower().startswith("ssh:")
               for ln in (cp.stderr or "").splitlines())


# ============================================================================
# PARSING  `btrfs subvolume show`
# ============================================================================

def _parse_dt(s: Optional[str]) -> Optional[datetime]:
    """Parse a Snapper/Btrfs timestamp into a NAIVE-UTC datetime. Handles
    info.xml's `YYYY-MM-DD HH:MM:SS` (UTC) and btrfs' `... +0000`. None on
    empty/'-'/unparseable so bucketing can fall back gracefully."""
    if not s:
        return None
    txt = s.strip()
    if not txt or txt == "-":
        return None
    for fmt in ("%Y-%m-%d %H:%M:%S %z", "%Y-%m-%d %H:%M:%S"):
        try:
            dt = datetime.strptime(txt, fmt)
            if dt.tzinfo is not None:
                dt = dt.astimezone(timezone.utc).replace(tzinfo=None)
            return dt
        except ValueError:
            continue
    return None


def parse_subvolume_show(text: str, path: str) -> Subvol:
    """Parse the human output of `btrfs subvolume show` into a Subvol. Field lines
    look like `Key:\\t\\tvalue`; matching is on a normalised lowercased prefix so
    btrfs-progs version differences don't matter."""
    uuid = parent_uuid = received_uuid = "-"
    readonly = False
    creation_time = None

    for line in text.splitlines():
        s = line.strip()
        low = s.lower()
        if low.startswith("received uuid:"):
            received_uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("parent uuid:"):
            parent_uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("uuid:"):
            uuid = s.split(":", 1)[1].strip() or "-"
        elif low.startswith("flags:"):
            readonly = "readonly" in low
        elif low.startswith("creation time:"):
            creation_time = _parse_dt(s.split(":", 1)[1])

    return Subvol(path=path, uuid=uuid, parent_uuid=parent_uuid,
                  received_uuid=received_uuid, readonly=readonly,
                  creation_time=creation_time)


def _ro_property_local(path: str) -> bool:
    cp = run_local(["btrfs", "property", "get", path, "ro"], check=False)
    return "ro=true" in cp.stdout.replace(" ", "").lower()


def _ro_property_remote(cfg: Config, path: str) -> bool:
    cp = run_remote(cfg, f"sudo btrfs property get {shlex.quote(path)} ro", check=False)
    return "ro=true" in cp.stdout.replace(" ", "").lower()


def show_local(path: str) -> Optional[Subvol]:
    cp = run_local(["btrfs", "subvolume", "show", path], check=False)
    if cp.returncode != 0:
        log_warn(f"btrfs subvolume show failed for {path}: {cp.stderr.strip()}")
        return None
    sv = parse_subvolume_show(cp.stdout, path)
    if "flags:" not in cp.stdout.lower():
        sv.readonly = _ro_property_local(path)
    return sv


def show_remote(cfg: Config, path: str) -> Optional[Subvol]:
    cp = run_remote(cfg, f"sudo btrfs subvolume show {shlex.quote(path)}", check=False)
    if cp.returncode != 0:
        return None
    sv = parse_subvolume_show(cp.stdout, path)
    if "flags:" not in cp.stdout.lower():
        sv.readonly = _ro_property_remote(cfg, path)
    return sv



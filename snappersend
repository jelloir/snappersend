def _read_info_xml(info_path: str):
    """Best-effort parse of Snapper's info.xml -> (num, date_str, type, pre_num)."""
    try:
        root = ET.parse(info_path).getroot()
        num = root.findtext("num")
        date = root.findtext("date")
        typ = root.findtext("type")
        pre = root.findtext("pre_num")
        return (
            int(num) if num and num.isdigit() else None,
            date.strip() if date else None,
            typ.strip() if typ else None,
            int(pre) if pre and pre.strip().isdigit() else None,
        )
    except Exception as e:
        log_debug(f"info.xml parse failed for {info_path}: {e}")
        return (None, None, None, None)


def _int_or_zero(s: str) -> int:
    return int(s) if s.isdigit() else 0


def list_snapper_snapshots(mountpoint: str) -> list[Subvol]:
    """Read Snapper's RO snapshots from <mountpoint>/.snapshots/<N>/snapshot plus
    info.xml. Only readonly snapshots are sendable, so RW ones are skipped."""
    snaps: list[Subvol] = []
    snap_root = os.path.join(mountpoint, ".snapshots")
    if not os.path.isdir(snap_root):
        log_warn(f"no .snapshots under {mountpoint} ({snap_root} absent)")
        return snaps

    for entry in sorted(os.listdir(snap_root), key=_int_or_zero):
        if not entry.isdigit():
            continue
        sub_path = os.path.join(snap_root, entry, "snapshot")
        if not os.path.isdir(sub_path):
            continue
        sv = show_local(sub_path)
        if sv is None:
            continue
        if not sv.readonly:
            log_debug(f"skipping non-readonly snapshot {sub_path}")
            continue
        sv.snapper_num = int(entry)
        info_path = os.path.join(snap_root, entry, "info.xml")
        if os.path.isfile(info_path):
            num, date, typ, pre = _read_info_xml(info_path)
            sv.snapper_time = date
            sv.info_time = _parse_dt(date)
            sv.snapper_type = typ
            sv.pre_num = pre
        snaps.append(sv)
    return snaps


def newest_snapshot(snaps: list[Subvol]) -> Optional[Subvol]:
    """Snapper's current newest by number (the only one the newest-only model sends)."""
    numbered = [s for s in snaps if s.snapper_num is not None]
    return max(numbered, key=lambda s: s.snapper_num) if numbered else None


def _parse_dt_name(s: str) -> Optional[datetime]:
    """Parse a colon-free `YYYYMMDD-HHMMSS±ZZZZ` name label into NAIVE-UTC. Falls
    back to the older minute-precision `YYYYMMDD-HHMM±ZZZZ` so names written by an
    earlier version still parse."""
    for fmt in ("%Y%m%d-%H%M%S%z", "%Y%m%d-%H%M%z"):
        try:
            aware = datetime.strptime(s, fmt)
            return aware.astimezone(timezone.utc).replace(tzinfo=None)
        except ValueError:
            continue
    return None


# A received/clone directory name. Both shapes share the same prefix:
#   destination receive dir : <localdate>-<offset>-<num>-<clone_short_uuid>
#   source parent-tree label: <localdate>-<offset>-<num>-<snapshot_short_uuid>
# <localdate> is SECOND precision (HHMMSS) so two snapshots in the same minute order
# correctly — minute precision was ambiguous and, combined with Snapper RECYCLING a
# number after a delete, could misorder "newest" and mis-pin retention. date+offset =
# group 1, num = group 2; num is terminated by '-' or end-of-string. The older
# minute-precision form (HHMM, 4 digits) is still accepted for back-compat.
_NAME_RE = re.compile(r"^(\d{8}-\d{4,6}[+-]\d{4})-(\d+)(?:-|$)")


def _apply_name_metadata(sv: Subvol, name: str) -> None:
    """Recover the ORIGINAL snapshot's num + time from a received/clone dir name and
    set them on the Subvol, so ordering/naming reflect the snapshot, not the clone."""
    m = _NAME_RE.match(name)
    if m:
        sv.snapper_num = int(m.group(2))
        parsed = _parse_dt_name(m.group(1))
        if parsed is not None:
            sv.info_time = parsed


def list_target_snapshots(cfg: Config, recv_dir: str) -> list[Subvol]:
    """List received subvolumes on the destination under recv_dir (over ssh). Each
    lives at `<recv_dir>/<name>/snapshot`; <name> carries the source snapshot's date
    + num (authoritative for ordering/retention). The `<base>.latest` symlink is
    skipped."""
    cp = run_remote(cfg, f"sudo ls -1 {shlex.quote(recv_dir)}", check=False)
    out: list[Subvol] = []
    if cp.returncode != 0:
        if _is_ssh_transport_failure(cp):
            summary = next((ln.strip() for ln in (cp.stderr or "").splitlines()
                            if ln.strip().lower().startswith("ssh:")),
                           f"ssh exited {cp.returncode}")
            raise RemoteUnreachable(summary)
        # Reachable, but the listing failed for a benign reason (e.g. the recv dir
        # doesn't exist yet on a genuine first run) — treat as 'no snapshots'.
        return out
    for name in cp.stdout.split():
        if name.endswith(".latest"):
            continue
        sv = show_remote(cfg, os.path.join(recv_dir, name, "snapshot"))
        if sv is None:
            continue
        _apply_name_metadata(sv, name)
        out.append(sv)
    return out


# ============================================================================
# PARENT-PRESERVATION TREE  (the central new mechanism)
# ============================================================================

def list_parent_clones(cfg: Config, subvol_name: str) -> list[Subvol]:
    """List the read-only parent clones under <parent_tree_base>/<subvol>/, newest
    first. Each clone lives at `<label>/snapshot` (mirroring Snapper's own wrapper +
    `snapshot` layout, so the subvol we send is literally named `snapshot` and
    receives in place). The clone's own uuid (what the destination correlates on)
    comes from `btrfs subvolume show`; its num + time are recovered from the <label>
    dir name (the original snapshot's identity)."""
    base = cfg.parent_dir_for(subvol_name)
    if not os.path.isdir(base):
        return []
    clones: list[Subvol] = []
    for label in os.listdir(base):
        path = os.path.join(base, label, "snapshot")
        if not os.path.isdir(path):
            continue
        sv = show_local(path)
        if sv is None:
            continue
        _apply_name_metadata(sv, label)
        clones.append(sv)
    clones.sort(key=lambda c: (c.when or datetime.min, c.snapper_num or 0),
                reverse=True)
    return clones


def choose_parent_clone(clones: list[Subvol],
                        target_snaps: list[Subvol]) -> Optional[Subvol]:
    """The send parent: the NEWEST clone that correlates with a snapshot the
    destination still holds (proving it is a valid `-p` base there). Naturally skips
    an orphan clone from a crash-before-receive (the destination never got it) and
    detects divergence (returns None -> full send). Selects by max time/num rather
    than trusting input order, so it is correct regardless of how `clones` is sorted."""
    correlating = [c for c in clones
                   if any(is_correlated(c, t) for t in target_snaps)]
    if not correlating:
        return None
    return max(correlating, key=lambda c: (c.when or datetime.min, c.snapper_num or 0))


def _name_date_part(dt: Optional[datetime]) -> str:
    """Render a naive-UTC instant as the colon-free, SECOND-precision local label
    `YYYYMMDD-HHMMSS±ZZZZ` used in clone labels and destination dir names."""
    if not dt:
        return "nodate"
    return dt.replace(tzinfo=timezone.utc).astimezone().strftime("%Y%m%d-%H%M%S%z")


def _short_uuid(uuid: str) -> str:
    return uuid.split("-")[0] if uuid not in ("", "-") else "nouuid"


def _clone_label(snap: Subvol) -> str:
    """Directory label for a clone of `snap`: <localdate>-<offset>-<num>-<short_uuid>,
    where short_uuid is the SOURCE SNAPSHOT's uuid. Derived purely from the snapshot,
    so a re-clone of the SAME snapshot is deterministic (an orphan from a crash is
    overwritten in place) while two DIFFERENT snapshots can never collide on a label —
    which is what prevents make_clone from ever deleting a still-needed parent when
    Snapper recycles a number into the same second."""
    num = snap.snapper_num if snap.snapper_num is not None else 0
    return f"{_name_date_part(snap.when)}-{num}-{_short_uuid(snap.uuid)}"


def make_clone(cfg: Config, subvol_name: str, snap: Subvol) -> Optional[Subvol]:
    """Stage a read-only clone of Snapper's snapshot `snap` in the parent tree and
    return it carrying `snap`'s num/time. The clone lands at `<label>/snapshot` so
    the subvol we later send is literally named `snapshot` (it then receives in place
    on the destination, rule 3). Reflink-shared (near-zero space) but an independent
    subvolume. A pre-existing clone at the same label is an orphan from a prior crash
    (we only get here when `snap` is NOT yet confirmed sent) and is replaced. The
    staged clone is RETAINED only if the subsequent send verifies — see
    replicate_subvol; on failure it is deleted (promote-on-confirmed-send)."""
    base = cfg.parent_dir_for(subvol_name)
    label = _clone_label(snap)
    wrapper = os.path.join(base, label)
    path = os.path.join(wrapper, "snapshot")

    if cfg.dry_run:
        log_info(f"[dry-run] would clone {snap.path} -> {path}")
        # Synthetic clone carrying snap's identity so the dry-run send log is realistic.
        c = Subvol(path=path, uuid=snap.uuid, parent_uuid=snap.uuid,
                   received_uuid="-", readonly=True)
        c.snapper_num, c.info_time = snap.snapper_num, snap.info_time
        return c

    if os.path.isdir(path):
        log_debug(f"replacing orphan clone {path}")
        delete_clone(path)
    os.makedirs(wrapper, exist_ok=True)
    cp = run_local(["btrfs", "subvolume", "snapshot", "-r", snap.path, path],
                   check=False)
    if cp.returncode != 0:
        log_error(f"failed to clone {snap.path} -> {path}: {cp.stderr.strip()}")
        with contextlib.suppress(OSError):
            os.rmdir(wrapper)
        return None
    clone = show_local(path)
    if clone is None:
        log_error(f"clone {path} unreadable after creation")
        return None
    clone.snapper_num, clone.info_time = snap.snapper_num, snap.info_time
    return clone


def delete_clone(path: str) -> None:
    """Delete a parent clone subvolume and its now-empty wrapper dir (best-effort).
    `path` is the `<label>/snapshot` subvol."""
    run_local(["btrfs", "subvolume", "delete", path], check=False)
    with contextlib.suppress(OSError):
        os.rmdir(os.path.dirname(path))


def prune_parent_clones(cfg: Config, subvol_name: str, keep: int) -> None:
    """Keep the newest `keep` clones; delete older ones. Space hygiene only —
    correctness comes from choose_parent_clone correlating against the destination,
    so an extra orphan never misleads parent selection."""
    clones = list_parent_clones(cfg, subvol_name)
    for old in clones[keep:]:
        if cfg.dry_run:
            log_info(f"[dry-run] would prune parent clone {old.path}")
            continue
        delete_clone(old.path)
        log_info(f"  pruned parent clone "
                 f"{os.path.basename(os.path.dirname(old.path))}")


# ============================================================================
# TRANSFER  (send the CLONE + rule 1 verification)
# ============================================================================

def send_receive(cfg: Config, clone: Subvol, recv_dir: str,
                 parent: Optional[Subvol]) -> bool:
    """
    Stream one parent-tree CLONE to the destination, then VERIFY it landed cleanly
    (rule 1). Returns True only on a verified-good receive. On garble (or pipe
    error) it deletes the partial subvol on the destination and returns False,
    leaving the existing chain intact for a clean retry.

    We send the clone (not Snapper's snapshot) so the destination's received_uuid
    equals the clone's uuid — the clone we retain IS the destination's correlation
    key. The destination dir is named from the ORIGINAL snapshot's date+num (carried
    on the clone) so the receive area sorts chronologically and retention buckets by
    snapshot time; the short_uuid is the clone's (what correlates). Receive-in-place
    (rule 3): we receive directly into the final per-transfer directory.
    """
    send_cmd = ["btrfs", "send"]
    if parent is not None:
        send_cmd += ["-p", parent.path]
    send_cmd += [clone.path]

    # The destination dir name carries the ORIGINAL snapshot's date (second precision)
    # + num for chronological sort/retention, and the CLONE's own short uuid (what the
    # destination correlates on) for uniqueness.
    date_part = _name_date_part(clone.when)
    short_uuid = _short_uuid(clone.uuid)
    num = clone.snapper_num if clone.snapper_num is not None else 0
    received_name = f"{date_part}-{num}-{short_uuid}"

    final_dir = os.path.join(recv_dir, received_name)
    final_path = os.path.join(final_dir, "snapshot")
    recv_remote = f"sudo btrfs receive {shlex.quote(final_dir)}"

    if cfg.dry_run:
        kind = f"-p {parent.path} " if parent else "(FULL) "
        log_info(f"[dry-run] btrfs send {kind}{clone.path} | ssh ... {recv_remote}"
                 f"  ->  {final_path}")
        return True

    _cleanup_final(cfg, final_dir)
    run_remote(cfg, f"sudo mkdir -p {shlex.quote(final_dir)}", check=False)

    pipe_ok = _run_pipe(send_cmd, ssh_argv(cfg, recv_remote), cfg.use_mbuffer)

    received_sv = show_remote(cfg, final_path)
    if received_sv is None or received_sv.is_garbled or not received_sv.is_valid_received:
        log_error(f"garbled/incomplete receive in {final_dir} — cleaning up")
        _cleanup_final(cfg, final_dir)
        return False
    if not pipe_ok:
        log_warn(f"pipe reported error though received subvol looks valid; "
                 f"discarding {final_dir} and retrying next run")
        _cleanup_final(cfg, final_dir)
        return False

    _update_latest_symlink(cfg, recv_dir, received_name)
    log_ok(f"received #{num} -> {received_name}/snapshot")
    return True


def _cleanup_final(cfg: Config, final_dir: str) -> None:
    """Remove a received (or partial) subvol + its per-transfer dir without needing
    `rm -rf` on the destination (keeps the transport sudoers grant tight)."""
    subvol = os.path.join(final_dir, "snapshot")
    run_remote(cfg, f"sudo btrfs subvolume delete {shlex.quote(subvol)}", check=False)
    run_remote(cfg, f"sudo rmdir {shlex.quote(final_dir)}", check=False)


def _run_pipe(send_argv, ssh_argv_list, use_mbuffer) -> bool:
    """
    Connect `btrfs send` -> [mbuffer ->] ssh receive and return True iff EVERY stage
    exits 0 (a failure in `btrfs send` must not be masked by a 0 from ssh). Each
    stage's stderr is captured to a temp file (never a pipe, so a chatty stage can't
    deadlock the data flow) — except interactive mbuffer, which inherits the terminal
    for its live throughput readout.
    """
    stages: list[tuple[str, list[str], bool]] = [("btrfs send", list(send_argv), True)]
    mb = bool(use_mbuffer) and shutil.which("mbuffer") is not None
    if use_mbuffer and not mb:
        log_warn("use_mbuffer set but mbuffer not on PATH; continuing without it")
    if mb:
        if sys.stderr.isatty():
            stages.append(("mbuffer", ["mbuffer", "-m", "256M"], False))
        else:
            stages.append(("mbuffer", ["mbuffer", "-q", "-m", "256M"], True))
    stages.append(("ssh receive", list(ssh_argv_list), True))

    procs: list[tuple[str, subprocess.Popen, object]] = []
    errfiles: list = []
    prev_stdout = None
    try:
        for i, (name, argv, capture) in enumerate(stages):
            errf = tempfile.TemporaryFile() if capture else None
            if errf is not None:
                errfiles.append(errf)
            is_last = (i == len(stages) - 1)
            p = subprocess.Popen(
                argv,
                stdin=prev_stdout,
                stdout=(subprocess.DEVNULL if is_last else subprocess.PIPE),
                stderr=errf,
            )
            if prev_stdout is not None:
                prev_stdout.close()
            procs.append((name, p, errf))
            prev_stdout = p.stdout
    except (FileNotFoundError, OSError) as e:
        log_error(f"failed to start pipe: {e}")
        for _, p, _ef in procs:
            with contextlib.suppress(Exception):
                p.kill()
        for ef in errfiles:
            with contextlib.suppress(Exception):
                ef.close()
        return False

    all_ok = True
    for name, p, errf in procs:
        rc = p.wait()
        err = ""
        if errf is not None:
            try:
                errf.seek(0)
                err = errf.read().decode("utf-8", "replace").strip()
            finally:
                errf.close()
        if rc != 0:
            all_ok = False
            log_error(f"  pipe stage '{name}' exited {rc}" + (f": {err}" if err else ""))
        elif err:
            log_debug(f"  pipe stage '{name}': {err}")
    return all_ok


def _update_latest_symlink(cfg: Config, recv_dir: str, name: str) -> None:
    """Maintain <recv_dir>/<subvol>.latest -> newest received SUBVOL, a stable
    target for a downstream archiver (e.g. restic) running on the destination."""
    base = os.path.basename(recv_dir.rstrip("/"))
    link = os.path.join(recv_dir, f"{base}.latest")
    target = os.path.join(recv_dir, name, "snapshot")
    run_remote(cfg, f"sudo ln -sfn {shlex.quote(target)} {shlex.quote(link)}", check=False)


# ============================================================================
# BOOT TIER  (non-Btrfs: EFI=FAT32, /boot=ext4 — rsync mirror, not versioned)
# ============================================================================

def boot_backup(cfg: Config, hostname: str) -> bool:
    """rsync each non-Btrfs boot path to <recv_base>/<hostname>/<name>/ over SSH.
    True iff every path synced cleanly. Fail-safe: a failure warns but does not
    abort the run (the boot tier is independent of the snapshot tiers)."""
    if not cfg.boot_backup_enabled:
        log_info("Boot backup disabled — skipping.")
        return True

    log_step(f"Boot mirror ({', '.join(cfg.boot_paths)} -> {cfg.recv_base}/{hostname}/)")
    rsh = f"ssh -i {cfg.ssh_key} -p {cfg.server_ssh_port} -o BatchMode=yes"
    all_ok = True

    for src in cfg.boot_paths:
        if not os.path.ismount(src) and not os.path.isdir(src):
            log_warn(f"  boot path {src} not present — skipping")
            continue
        name = src.strip("/").replace("/", "-")   # /boot -> boot, /boot/efi -> boot-efi
        dest = f"{cfg.recv_base}/{hostname}/{name}"
        run_remote(cfg, f"sudo mkdir -p {shlex.quote(dest)}", check=False)

        rsync_argv = [
            "rsync", "-aAX", "--delete",
            "-e", rsh,
            "--rsync-path", "sudo rsync",
            f"{src.rstrip('/')}/",
            f"{cfg.server_user}@{cfg.server_host}:{dest}/",
        ]
        if cfg.dry_run:
            log_info(f"[dry-run] rsync {src}/ -> {dest}/")
            continue

        cp = run_local(rsync_argv, check=False)
        # EFI (FAT32) has no perms/ACLs/xattrs, so -aAX emits benign warnings (rc 24
        # = vanished files). Treat rc 0 and 24 as success; warn (don't fail) otherwise.
        if cp.returncode in (0, 24):
            log_ok(f"  {src} mirrored to {dest}")
        else:
            log_warn(f"  rsync of {src} failed (rc={cp.returncode}) — continuing; "
                     "boot tier is independent of the snapshot tiers"
                     + (f": {cp.stderr.strip()}" if cp.stderr.strip() else ""))
            all_ok = False
    return all_ok


# ============================================================================
# RETENTION  (WYSIWYG pure GFS over the destination + the one pinned-parent asterisk)
# ============================================================================

# Tier codes -> human names, in the fixed grandfather-father-son order the loop walks.
_TIER_ORDER = ("h", "d", "w", "m", "y")
_TIER_CODE_LABEL = {"h": "hourly", "d": "daily", "w": "weekly",
                    "m": "monthly", "y": "yearly"}
# Sentinel used in _bucket_attribute for an undatable target (always kept, no tier).
_UNDATABLE = "undatable"


def _bucket_attribute(targets_newest_first: list[Subvol],
                      keep_hourly: int, keep_daily: int, keep_weekly: int,
                      keep_monthly: int, keep_yearly: int,
                      tz: str = "local") -> dict:
    """
    THE ONE COPY of the GFS bucketing loop. Walks already-newest-first targets and
    records, per KEPT path, WHICH tier(s) caused it to be kept — returning
    `{target.path: [tier_code, ...]}` where each tier_code is one of 'h','d','w','m','y'
    (in that grandfather-father-son order) or the sentinel `_UNDATABLE`. A path can
    occupy several tiers at once (the newest snapshot is simultaneously the hourly,
    daily, weekly, ... survivor); every tier it satisfies is recorded, coarsest-last.

    `_bucket_keep` derives its keep-SET as `set(this.keys())`, so retention and any
    reporting view share the exact same logic and can never drift. See `_bucket_keep`
    for the tz/boundary semantics — this is that function with attribution bolted on.
    """
    attrib: dict = {}
    last = {"h": None, "d": None, "w": None, "m": None, "y": None}
    cnt = {"h": 0, "d": 0, "w": 0, "m": 0, "y": 0}
    lim = {"h": keep_hourly, "d": keep_daily, "w": keep_weekly,
           "m": keep_monthly, "y": keep_yearly}

    for t in targets_newest_first:
        w = t.when
        if w is None:
            attrib.setdefault(t.path, []).append(_UNDATABLE)
            continue
        keyed = w.replace(tzinfo=timezone.utc).astimezone() if tz == "local" else w
        iso = keyed.isocalendar()
        keys = {
            "h": (keyed.year, keyed.month, keyed.day, keyed.hour),
            "d": (keyed.year, keyed.month, keyed.day),
            "w": (iso[0], iso[1]),
            "m": (keyed.year, keyed.month),
            "y": (keyed.year,),
        }
        for p in _TIER_ORDER:
            if lim[p] > 0 and keys[p] != last[p] and cnt[p] < lim[p]:
                attrib.setdefault(t.path, []).append(p)
                last[p] = keys[p]
                cnt[p] += 1
    return attrib


def _bucket_keep(targets_newest_first: list[Subvol],
                 keep_hourly: int, keep_daily: int, keep_weekly: int,
                 keep_monthly: int, keep_yearly: int, tz: str = "local") -> set:
    """
    GFS (grandfather-father-son) keep-set over already-newest-first targets. Returns
    the set of target.path to KEEP: the newest snapshot of each of the most recent
    `keep_<tier>` distinct buckets, unioned across hourly/daily/weekly/monthly/yearly.
    Undatable targets are always kept (we never delete what we can't place).

    Bucket BOUNDARIES are computed in `tz`: "local" (default) aligns hour/day/week/
    month/year boundaries to this machine's local calendar; "utc" uses UTC. Only the
    bucket-KEY extraction is zone-aware; `when` is a true instant (naive-UTC) and the
    newest-first ORDERING is by that instant, which a zone shift never changes.
    A tier with keep == 0 is disabled (the `lim[p] > 0` guard).

    Derived from `_bucket_attribute` so the bucketing logic lives in EXACTLY ONE place:
    the keep-set is precisely the set of paths the attribution helper tiered as kept.
    """
    return set(_bucket_attribute(targets_newest_first, keep_hourly, keep_daily,
                                 keep_weekly, keep_monthly, keep_yearly, tz))


def _keep_prepost_partners(keep_paths: set, source_snaps: list[Subvol],
                           target_snaps: list[Subvol]) -> set:
    """Root-only nicety: avoid orphaning half an apt pre/post pair. For every kept
    target whose correlated source is a 'post' (or 'pre'), also keep the target
    correlated with its partner. Best-effort; silently does nothing when the source
    side has already been pruned by Snapper. Composes fine with pure GFS."""
    extra: set = set()

    def corr_source(t: Subvol) -> Optional[Subvol]:
        for s in source_snaps:
            if is_correlated(s, t):
                return s
        return None

    tgt_by_src_num: dict = {}
    src_of_tgt: dict = {}
    for t in target_snaps:
        s = corr_source(t)
        if s and s.snapper_num is not None:
            tgt_by_src_num[s.snapper_num] = t
            src_of_tgt[t.path] = s

    for t in target_snaps:
        if t.path not in keep_paths:
            continue
        s = src_of_tgt.get(t.path)
        if not s:
            continue
        if s.snapper_type == "post" and s.pre_num is not None:
            partner = tgt_by_src_num.get(s.pre_num)
            if partner:
                extra.add(partner.path)
        elif s.snapper_type == "pre" and s.snapper_num is not None:
            for s2 in source_snaps:
                if s2.snapper_type == "post" and s2.pre_num == s.snapper_num:
                    partner = tgt_by_src_num.get(s2.snapper_num)
                    if partner:
                        extra.add(partner.path)
    return extra


def pinned_target(clones: list[Subvol], target_snaps: list[Subvol]) -> Optional[Subvol]:
    """The destination snapshot the NEXT incremental will parent against: the dest
    copy correlating with the newest parent clone. Never pruned (the one WYSIWYG
    exception) so the chain base always survives."""
    parent = choose_parent_clone(clones, target_snaps)
    if parent is None:
        return None
    for t in target_snaps:
        if is_correlated(parent, t):
            return t
    return None


def apply_retention(cfg: Config, subvol_name: str, source_snaps: list[Subvol],
                    target_snaps: list[Subvol], clones: list[Subvol],
                    recv_dir: str) -> None:
    """
    Prune the DESTINATION to EXACTLY the GFS keep-set (WYSIWYG) plus the single
    pinned parent. No source-backed union, no override logging — what the policy
    says is what survives. Source snapshots are never touched (Snapper owns them).
    """
    policy = cfg.retention_for(subvol_name)
    kh = int(policy.get("keep_hourly", 0))
    kd = int(policy.get("keep_daily", 0))
    kw = int(policy.get("keep_weekly", 0))
    km = int(policy.get("keep_monthly", 0))
    ky = int(policy.get("keep_yearly", 0))

    pin = pinned_target(clones, target_snaps)
    log_step(f"[{subvol_name}] retention (WYSIWYG GFS) hourly={kh} daily={kd} "
             f"weekly={kw} monthly={km} yearly={ky}; pinned parent="
             f"{os.path.basename(os.path.dirname(pin.path)) if pin else None}")

    if not target_snaps:
        return

    targets_sorted = sorted(target_snaps, key=lambda t: (t.when or datetime.min),
                            reverse=True)
    keep_paths = _bucket_keep(targets_sorted, kh, kd, kw, km, ky,
                              cfg.retention_timezone)

    # The one documented exception to WYSIWYG: never prune the incremental base.
    if pin is not None:
        keep_paths.add(pin.path)

    if subvol_name == "root":
        keep_paths |= _keep_prepost_partners(keep_paths, source_snaps, target_snaps)

    to_delete = [t for t in target_snaps if t.path not in keep_paths]
    log_info(f"[{subvol_name}] retention: {len(keep_paths)} kept "
             f"(GFS + pinned parent), {len(to_delete)} pruned.")
    if not to_delete:
        return

    for t in to_delete:
        wrapper_dir = os.path.dirname(t.path)
        if cfg.dry_run:
            log_info(f"[dry-run] would prune {wrapper_dir}")
            continue
        cp = run_remote(cfg, f"sudo btrfs subvolume delete {shlex.quote(t.path)}",
                        check=False)
        if cp.returncode == 0:
            run_remote(cfg, f"sudo rmdir {shlex.quote(wrapper_dir)}", check=False)
            log_info(f"  pruned {os.path.basename(wrapper_dir)}")
        else:
            log_warn(f"  failed to prune {t.path}: {cp.stderr.strip()}")

    if not cfg.dry_run:
        survivors = [t for t in target_snaps if t.path in keep_paths]
        if survivors:
            newest = max(survivors, key=lambda t: (t.when or datetime.min))
            _update_latest_symlink(cfg, recv_dir,
                                   os.path.basename(os.path.dirname(newest.path)))


# ============================================================================
# MAIN PER-SUBVOL FLOW  (newest-only + parent tree + promote-on-confirmed-send)
# ============================================================================

def replicate_subvol(cfg: Config, name: str, mountpoint: str, recv_dir: str) -> bool:
    """Full flow for one subvol: pick newest Snapper snapshot -> choose preserved
    parent -> (skip if already sent) -> stage clone -> send -> verify -> promote ->
    prune parent tree -> WYSIWYG retention."""
    log_step(f"Replicating '{name}' ({mountpoint} -> {recv_dir})")

    source_snaps = list_snapper_snapshots(mountpoint)
    newest = newest_snapshot(source_snaps)
    if newest is None:
        log_info(f"No snapper snapshots under {mountpoint}/.snapshots — nothing to do.")
        return True

    run_remote(cfg, f"sudo mkdir -p {shlex.quote(recv_dir)}", check=False)
    try:
        target_snaps = list_target_snapshots(cfg, recv_dir)
    except RemoteUnreachable as e:
        # Transport down — NOT divergence. Abort this subvol WITHOUT staging or
        # pruning anything: the parent tree (and its correlation with whatever the
        # destination already holds) is left byte-for-byte intact, so the next run
        # resumes with a normal incremental instead of being forced into a full send.
        log_error(f"[{name}] destination unreachable ({e}) — skipping this subvol; "
                  "parent tree left intact, will retry next run.")
        return False
    clones = list_parent_clones(cfg, name)

    parent = choose_parent_clone(clones, target_snaps)
    log_info(f"[{name}] newest snapper #{newest.snapper_num}; "
             f"{len(clones)} parent clone(s); {len(target_snaps)} on destination; "
             f"parent={'#' + str(parent.snapper_num) if parent else 'none (full send)'}")

    # Idempotent re-run: if a clone of the current newest already correlates with the
    # destination, this snapshot is already replicated — go straight to retention.
    already = any(c.snapper_num == newest.snapper_num and
                  any(is_correlated(c, t) for t in target_snaps)
                  for c in clones)
    if already:
        log_info(f"[{name}] newest #{newest.snapper_num} already on destination — "
                 "no send needed.")
    else:
        if parent is None:
            log_info(f"[{name}] no shared parent with destination — full send "
                     f"(first run or divergence) of #{newest.snapper_num}.")
        # Stage the clone we will actually send (promote-on-confirmed-send: it is
        # retained only if the send verifies, else deleted below).
        clone = make_clone(cfg, name, newest)
        if clone is None:
            log_error(f"[{name}] could not stage parent clone — aborting subvol.")
            return False

        if not send_receive(cfg, clone, recv_dir, parent):
            log_error(f"[{name}] transfer of #{newest.snapper_num} failed; "
                      "deleting staged clone, leaving prior parent intact for retry.")
            if not cfg.dry_run:
                delete_clone(clone.path)
            return False

        # Verified-good receive: the staged clone is now confirmed -> promote by
        # keeping it and pruning the tree to parent_keep.
        prune_parent_clones(cfg, name, cfg.parent_keep)
        if not cfg.dry_run:
            target_snaps = list_target_snapshots(cfg, recv_dir)
            clones = list_parent_clones(cfg, name)

    apply_retention(cfg, name, source_snaps, target_snaps, clones, recv_dir)
    return True


# ============================================================================
# RUN LOCK  (so two runs can't overlap — the future watchdog relies on it)
# ============================================================================

class _AlreadyRunning(Exception):
    pass


@contextlib.contextmanager
def run_lock(path: Optional[str] = None):
    """flock a lockfile for the whole run. If another run holds it, raise
    _AlreadyRunning (main exits cleanly). If the lockfile can't be opened (e.g.
    unprivileged dev run), warn and proceed lock-less rather than abort."""
    path = path or os.environ.get("SNAPPERSEND_LOCK", "/var/lock/snappersend.lock")
    try:
        f = open(path, "w")
    except OSError as e:
        log_warn(f"could not open lockfile {path} ({e}); proceeding without lock")
        yield
        return
    try:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        f.close()
        log_error(f"another snappersend run holds {path}; exiting")
        raise _AlreadyRunning()
    try:
        yield
    finally:
        with contextlib.suppress(Exception):
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)
        f.close()


def _write_success_stamp() -> None:
    """Touch a stamp the future watchdog reads to detect missed/failed runs."""
    stamp = os.environ.get("SNAPPERSEND_STAMP", "/var/lib/snappersend/last-success")
    try:
        os.makedirs(os.path.dirname(stamp), exist_ok=True)
        with open(stamp, "w") as f:
            f.write(datetime.now().strftime("%Y-%m-%d %H:%M:%S\n"))
    except OSError as e:
        log_debug(f"could not write success stamp {stamp}: {e}")


# ============================================================================
# REPORT  (read-only: derive live tiers + KEEP/PRUNE from the SAME retention logic)
# ============================================================================
# --report shows, per subvol, how the destination snapshots and source parent clones
# stand RIGHT NOW: their current GFS tier (recomputed live — a tier is never stored),
# what the next retention run would KEEP vs PRUNE, and chain/lag health. It mutates
# NOTHING: no sends, clones, deletes, renames, property writes, mkdir, symlink, or
# success stamp. Tiers are derived from `_bucket_attribute` — the same loop retention
# uses — so this view can never disagree with what a real run would actually prune.


def _fmt_when(dt: Optional[datetime]) -> str:
    """Render a naive-UTC instant as a readable LOCAL `YYYY-MM-DD HH:MM` for the human
    report (the stored/label times are naive-UTC; the operator thinks in local time)."""
    if not dt:
        return "unknown-date"
    return dt.replace(tzinfo=timezone.utc).astimezone().strftime("%Y-%m-%d %H:%M")


def _label_of(sv: Subvol) -> str:
    """The on-disk wrapper dir name (`<date>-<offset>-<num>-<uuid>`) for a received
    target or a parent clone — both live at `<label>/snapshot`."""
    return os.path.basename(os.path.dirname(sv.path))


def _dest_reasons(t: Subvol, attrib: dict, pin: Optional[Subvol],
                  prepost_extra: set) -> list[str]:
    """The human reason(s) a destination snapshot is (or isn't) kept, mirroring exactly
    how apply_retention builds its keep-set: GFS tier(s) from `attrib`, plus the
    keeps that live OUTSIDE GFS — the pinned parent and (root) pre/post partner — shown
    as their own reasons, never as a tier."""
    reasons: list[str] = []
    codes = attrib.get(t.path, [])
    if _UNDATABLE in codes:
        reasons.append("kept (undatable)")
    else:
        reasons.extend(_TIER_CODE_LABEL[c] for c in codes)
    if pin is not None and t.path == pin.path:
        reasons.append("pinned parent")
    if t.path in prepost_extra:
        reasons.append("prepost partner")
    return reasons


def _report_subvol(cfg: Config, name: str, mountpoint: str, recv_dir: str) -> None:
    """Print the read-only report for one subvol. Never touches disk on either host
    beyond the reads (list snapper snapshots / parent clones / target snapshots)."""
    print(f"\n=== {name}  ({mountpoint} -> {recv_dir}) ===")

    source_snaps = list_snapper_snapshots(mountpoint)
    clones = list_parent_clones(cfg, name)

    dest_unreachable = False
    unreachable_reason = ""
    target_snaps: list[Subvol] = []
    try:
        target_snaps = list_target_snapshots(cfg, recv_dir)
    except RemoteUnreachable as e:
        dest_unreachable = True
        unreachable_reason = str(e)

    policy = cfg.retention_for(name)
    kh = int(policy.get("keep_hourly", 0))
    kd = int(policy.get("keep_daily", 0))
    kw = int(policy.get("keep_weekly", 0))
    km = int(policy.get("keep_monthly", 0))
    ky = int(policy.get("keep_yearly", 0))

    # --- Destination snapshots -------------------------------------------------
    print(f"  Destination snapshots  (policy: hourly={kh} daily={kd} weekly={kw} "
          f"monthly={km} yearly={ky}, tz={cfg.retention_timezone}):")
    if dest_unreachable:
        print(f"    unreachable — cannot report dest tiers ({unreachable_reason})")
        parent = clones[0] if clones else None        # presumptive: newest local clone
        parent_presumed = True
    else:
        parent = choose_parent_clone(clones, target_snaps)
        parent_presumed = False
        if not target_snaps:
            print("    (none on destination)")
        else:
            # Recompute the keep decision EXACTLY as apply_retention does, so the
            # KEEP/PRUNE verdicts here are the plan the next run would execute.
            targets_sorted = sorted(target_snaps,
                                    key=lambda t: (t.when or datetime.min), reverse=True)
            attrib = _bucket_attribute(targets_sorted, kh, kd, kw, km, ky,
                                       cfg.retention_timezone)
            keep_paths = set(attrib)
            pin = pinned_target(clones, target_snaps)
            if pin is not None:
                keep_paths.add(pin.path)
            prepost_extra: set = set()
            if name == "root":
                prepost_extra = _keep_prepost_partners(keep_paths, source_snaps,
                                                       target_snaps)
                keep_paths |= prepost_extra

            for t in targets_sorted:
                verdict = "KEEP " if t.path in keep_paths else "PRUNE"
                reasons = _dest_reasons(t, attrib, pin, prepost_extra)
                reason_txt = ", ".join(reasons) if reasons else "-"
                garble = "  GARBLE!" if (t.is_garbled or not t.is_valid_received) else ""
                num = t.snapper_num if t.snapper_num is not None else "?"
                print(f"    {verdict}  #{num:<4} {_fmt_when(t.when)}  "
                      f"[{reason_txt}]{garble}")

    # --- Source parent clones --------------------------------------------------
    n = len(clones)
    if n > cfg.parent_keep:
        tree_state = f"over target (prunes to {cfg.parent_keep} after next good send)"
    elif n == cfg.parent_keep:
        tree_state = "at target"
    else:
        tree_state = "under target (building up)"
    print(f"  Source parent clones  ({n} clone(s), parent_keep={cfg.parent_keep} — "
          f"{tree_state}):")
    if not clones:
        print("    (none — next run will full-send)")
    for c in clones:
        is_parent = parent is not None and c.path == parent.path
        if is_parent:
            mark = "* parent (presumed)" if parent_presumed else "* parent"
        else:
            mark = ""
        if dest_unreachable:
            corr = "correlation unknown (dest unreachable)"
        else:
            corr = ("correlates with dest"
                    if any(is_correlated(c, t) for t in target_snaps)
                    else "NOT correlated (orphan)")
        num = c.snapper_num if c.snapper_num is not None else "?"
        print(f"    #{num:<4} {_fmt_when(c.when)}  {corr}  {mark}".rstrip())

    # --- Per-subvol health lines ----------------------------------------------
    if dest_unreachable:
        print("  Chain: unknown — destination unreachable")
        print("  Lag:   unknown — destination unreachable")
        return

    if parent is None:
        print("  Chain: WARN — next run will full-send "
              "(no parent clone correlates with any destination snapshot)")
    else:
        newest_dest = max(target_snaps, key=lambda t: (t.when or datetime.min),
                          default=None)
        newest_clone = clones[0] if clones else None
        intact = (newest_clone is not None and newest_dest is not None
                  and is_correlated(newest_clone, newest_dest))
        if intact:
            print(f"  Chain: intact — next incremental parents off #{parent.snapper_num}")
        else:
            print(f"  Chain: intact but behind — next incremental parents off "
                  f"#{parent.snapper_num} (newest clone not yet on destination)")

    src_newest = newest_snapshot(source_snaps)
    dst_newest = max(target_snaps, key=lambda t: (t.when or datetime.min),
                     default=None) if target_snaps else None
    if src_newest is None:
        print("  Lag:   no source snapshots")
    elif dst_newest is None:
        print(f"  Lag:   WARN — source at #{src_newest.snapper_num}, "
              "destination has NOTHING (never replicated / stalled)")
    else:
        gap = src_newest.snapper_num - dst_newest.snapper_num
        when_txt = ""
        if src_newest.when and dst_newest.when:
            secs = int((src_newest.when - dst_newest.when).total_seconds())
            if secs > 0:
                d, rem = divmod(secs, 86400)
                h, rem = divmod(rem, 3600)
                m = rem // 60
                parts = ([f"{d}d"] if d else []) + ([f"{h}h"] if h else []) \
                    + ([f"{m}m"] if (m and not d) else [])
                when_txt = f", {' '.join(parts)} of wall-clock" if parts else ""
        flag = "" if gap <= 0 else "  (destination is behind)"
        print(f"  Lag:   source newest #{src_newest.snapper_num} vs destination "
              f"newest #{dst_newest.snapper_num} — {max(gap, 0)} snapshot(s) behind"
              f"{when_txt}{flag}")


def _report(cfg: Config, args: argparse.Namespace) -> int:
    """Read-only report across the configured subvols. Takes NO run lock and writes NO
    success stamp — it mutates nothing, so it never blocks or interferes with a
    concurrent real run. Returns 0."""
    hostname = socket.gethostname()
    print(f"snappersend report — {hostname} -> {cfg.server_user}@{cfg.server_host}")
    print("(read-only; tiers computed live from current retention policy — a "
          "snapshot's tier changes as newer ones age out)")
    for name, sv in cfg.subvols.items():
        if args.subvol and name != args.subvol:
            continue
        recv_dir = cfg.recv_dir_for(hostname, name)
        try:
            _report_subvol(cfg, name, sv["mountpoint"], recv_dir)
        except Exception as e:   # a broken subvol must not abort the whole report
            print(f"\n=== {name} ===\n  ERROR building report: {e}")
    return 0


# ============================================================================
# DESTINATION PROVISIONING  (setup-dest / decom-dest — no files shipped to dest)
# ============================================================================
# The destination runs no snappersend code: every remote command is a stock tool
# (`btrfs receive`, `rsync`, `mkdir`, ...) invoked as `ssh <user> "sudo <cmd>"`. So
# onboarding is pure config: a dedicated transport user, a `restrict`-hardened
# authorized_keys line, and ONE scoped /etc/sudoers.d/snappersend. There is NO
# forced-command wrapper script on the destination — the scoped sudoers grant is the
# security boundary, and `restrict` denies the transport key a pty/forwarding. That
# keeps the destination footprint to a user + one sudoers file + one key line, all
# trivially removable by decom-dest (which never touches the received data).
#
# setup-dest bootstraps that config over the OPERATOR'S OWN admin login to the
# destination (like a privileged ssh-copy-id): it must run as root locally (it writes
# /etc/snappersend and /root/.ssh), but the OUTBOUND admin ssh is executed as the
# invoking user ($SUDO_USER) so it uses their credentials, not root's.


def _admin_ssh_argv(admin_user: str, host: str, port: int,
                    tty: bool = False) -> list[str]:
    """ssh argv for the one-time admin bootstrap connection. Runs as the invoking
    user ($SUDO_USER) when we are root under sudo, so it uses the operator's keys/
    known_hosts rather than root's. accept-new pins the host on first contact. `tty`
    forces a remote pseudo-terminal (-tt) so a destination `sudo` can prompt for a
    password — the common case; passwordless sudo is only our test setup."""
    base = ["ssh"]
    if tty:
        base.append("-tt")
    base += ["-o", "StrictHostKeyChecking=accept-new",
             "-o", "ConnectTimeout=15", "-p", str(port), f"{admin_user}@{host}"]
    sudo_user = os.environ.get("SUDO_USER")
    if os.geteuid() == 0 and sudo_user and sudo_user != "root":
        return ["sudo", "-H", "-u", sudo_user, "--"] + base
    return base


def _run_admin_script(admin_user: str, host: str, port: int, script: str):
    """Run `script` as root on the destination over the admin login. Returns
    (rc, stdout, stderr).

    The script is passed base64-encoded as a command ARGUMENT (not on stdin) so the
    destination's `sudo` can read a password from the terminal while bash reads the
    script from the pipe. Interactively (a tty) we allocate a remote pty and INHERIT
    the terminal so the sudo prompt is shown and answerable — success is then judged by
    exit code. Non-interactively (cron/CI, no tty) we use `sudo -n` and CAPTURE output;
    that path requires passwordless sudo."""
    b64 = base64.b64encode(script.encode()).decode()
    interactive = sys.stdin.isatty()
    sudo = "sudo" if interactive else "sudo -n"
    remote = f"printf %s {shlex.quote(b64)} | base64 -d | {sudo} bash"
    argv = _admin_ssh_argv(admin_user, host, port, tty=interactive) + [remote]
    log_debug("admin: " + " ".join(shlex.quote(a) for a in argv))
    try:
        if interactive:
            # Inherit the terminal so `sudo` can prompt; we can't also capture stdout,
            # so success is the exit code (the remote script is `set -euo pipefail`).
            cp = subprocess.run(argv)
            return cp.returncode, "", ""
        cp = subprocess.run(argv, text=True, capture_output=True)
        return cp.returncode, cp.stdout, cp.stderr
    except FileNotFoundError as e:
        return 127, "", str(e)


def _provision_script(user: str, pubkey: str, recv_base: str) -> str:
    """The bash executed as root on the destination to (idempotently) create the
    transport user, install its restrict-hardened authorized_keys, write a scoped
    sudoers with the destination's OWN binary paths (auto-detected), and ensure the
    receive dir. Emits a final PROVISION_OK line the caller checks for."""
    authline = "restrict " + pubkey.strip()
    return f"""set -euo pipefail
U={shlex.quote(user)}
RECV_BASE={shlex.quote(recv_base)}
AUTHLINE={shlex.quote(authline)}
if ! id "$U" >/dev/null 2>&1; then
  useradd --system --create-home --shell /bin/bash "$U"
fi
passwd -l "$U" >/dev/null 2>&1 || true
install -d -m 700 -o "$U" -g "$U" "/home/$U/.ssh"
printf '%s\\n' "$AUTHLINE" > "/home/$U/.ssh/authorized_keys"
chown "$U:$U" "/home/$U/.ssh/authorized_keys"
chmod 600 "/home/$U/.ssh/authorized_keys"
BTRFS="$(command -v btrfs || true)"
RSYNC="$(command -v rsync || echo /usr/bin/rsync)"
MKDIR="$(command -v mkdir)"; RMDIR="$(command -v rmdir)"
LS="$(command -v ls)"; LN="$(command -v ln)"
if [ -z "$BTRFS" ]; then echo "btrfs not found on destination" >&2; exit 3; fi
umask 077
cat > /etc/sudoers.d/snappersend <<SUDOERS
Cmnd_Alias SNAPPERSEND_CMDS = \\
    $BTRFS receive *, \\
    $BTRFS subvolume show *, \\
    $BTRFS subvolume delete *, \\
    $BTRFS property get *, \\
    $MKDIR -p *, \\
    $RMDIR *, \\
    $LS *, \\
    $LN -sfn *, \\
    $RSYNC *
$U ALL=(root) NOPASSWD: SNAPPERSEND_CMDS
Defaults!SNAPPERSEND_CMDS !requiretty
SUDOERS
chmod 0440 /etc/sudoers.d/snappersend
if ! visudo -cf /etc/sudoers.d/snappersend; then
  rm -f /etc/sudoers.d/snappersend
  echo "sudoers validation failed" >&2; exit 4
fi
mkdir -p "$RECV_BASE"
chown "$U:$U" "$RECV_BASE"
echo "PROVISION_OK user=$U btrfs=$BTRFS rsync=$RSYNC"
"""


def _deprovision_script(user: str, recv_base: str, host_subdir: str,
                        purge_data: bool) -> str:
    """The bash executed as root on the destination to remove the transport config:
    the sudoers file and the transport user (with its home, hence its authorized_keys).
    Received data under RECV_BASE is PRESERVED unless purge_data, which additionally
    deletes THIS host's received subvolumes. Emits a final DECOM_OK line."""
    purge = ""
    if purge_data:
        hostdir = os.path.join(recv_base, host_subdir)
        purge = f"""
HOSTDIR={shlex.quote(hostdir)}
if [ -d "$HOSTDIR" ]; then
  for d in "$HOSTDIR"/*/; do
    [ -d "${{d}}snapshot" ] && btrfs subvolume delete "${{d}}snapshot" 2>/dev/null || true
    rm -rf "$d" 2>/dev/null || true
  done
  rmdir "$HOSTDIR" 2>/dev/null || true
  echo "purged received data under $HOSTDIR"
fi
"""
    return f"""set -euo pipefail
U={shlex.quote(user)}
rm -f /etc/sudoers.d/snappersend
if id "$U" >/dev/null 2>&1; then
  userdel --remove "$U" 2>/dev/null || userdel "$U" 2>/dev/null || true
fi
{purge}echo "DECOM_OK user=$U"
"""


def _ensure_transport_key(cfg: Config) -> bool:
    """Generate the passwordless ed25519 transport key at cfg.ssh_key if absent
    (root-owned tree). Returns True on success/already-present."""
    if os.path.isfile(cfg.ssh_key):
        return True
    keydir = os.path.dirname(cfg.ssh_key)
    try:
        os.makedirs(keydir, mode=0o700, exist_ok=True)
    except OSError as e:
        print(f"cannot create key dir {keydir}: {e}", file=sys.stderr)
        return False
    cp = run_local(["ssh-keygen", "-t", "ed25519", "-N", "", "-q",
                    "-C", f"snappersend@{socket.gethostname()}", "-f", cfg.ssh_key],
                   check=False)
    if cp.returncode != 0:
        print(f"ssh-keygen failed: {cp.stderr.strip()}", file=sys.stderr)
        return False
    print(f"  generated transport key {cfg.ssh_key}")
    return True


def _pin_host_key(host: str, port: int) -> bool:
    """Pin the destination's host key into ROOT's known_hosts so the transport
    (which runs as root with BatchMode) trusts it deterministically. Idempotent:
    stale entries for the host are removed first."""
    kh = "/root/.ssh/known_hosts"
    try:
        os.makedirs("/root/.ssh", mode=0o700, exist_ok=True)
    except OSError:
        pass
    run_local(["ssh-keygen", "-R", host, "-f", kh], check=False)
    scan = run_local(["ssh-keyscan", "-p", str(port), host], check=False)
    if scan.returncode == 0 and scan.stdout.strip():
        with open(kh, "a", encoding="utf-8") as f:
            f.write(scan.stdout)
        os.chmod(kh, 0o600)
        return True
    print(f"  WARN: ssh-keyscan of {host} returned nothing; transport may prompt on "
          "host key", file=sys.stderr)
    return False


def _verify_transport(cfg: Config):
    """Prove the transport end-to-end (host key + key auth + remote sudo) with an
    allowlisted `sudo ls` of RECV_BASE. Returns (ok, message)."""
    cp = run_remote(cfg, f"sudo ls -1d {shlex.quote(cfg.recv_base)}", check=False)
    if cp.returncode == 0 and cfg.recv_base in (cp.stdout or ""):
        return True, (f"{cfg.server_user}@{cfg.server_host} reachable, remote sudo OK, "
                      f"{cfg.recv_base} present")
    if _is_ssh_transport_failure(cp):
        detail = (cp.stderr or "").strip().splitlines()
        return False, "ssh transport failure: " + (detail[-1] if detail else
                                                    f"exit {cp.returncode}")
    return False, f"unexpected (rc={cp.returncode}): {(cp.stderr or '').strip()}"


def _resolve_admin(args: argparse.Namespace, cfg: Config):
    """Work out (admin_user, host, port) for the bootstrap login from the optional
    `admin` positional (user@host or bare user) or an interactive prompt. The host
    defaults to cfg.server_host; the transport still targets cfg.server_host."""
    admin = getattr(args, "admin", None)
    if not admin:
        if not sys.stdin.isatty():
            print("no admin login given and not a tty; pass e.g. "
                  f"'setup-dest admin@{cfg.server_host}'", file=sys.stderr)
            return None
        admin = input(f"Admin login on {cfg.server_host} (user@host, or just user): ").strip()
    if not admin:
        return None
    if "@" in admin:
        user, host = admin.split("@", 1)
    else:
        user, host = admin, cfg.server_host
    return user, host or cfg.server_host, cfg.server_ssh_port


_CONFIG_TEMPLATE = """\
# snappersend config — written by `snappersend setup-dest`
SERVER_HOST="{server_host}"
SSH_PORT="{ssh_port}"
SERVER_USER="{server_user}"
SSH_KEY="{ssh_key}"
RECV_BASE="{recv_base}"
USE_MBUFFER="yes"
BOOT_ENABLED="yes"
BOOT_PATHS="/boot /boot/efi"
SUBVOLUMES="{subvolumes}"
PARENT_TREE_BASE="/.snappersend"
PARENT_KEEP="2"
RETENTION_TIMEZONE="local"
TIMELINE_LIMIT_HOURLY="24"
TIMELINE_LIMIT_DAILY="14"
TIMELINE_LIMIT_WEEKLY="8"
TIMELINE_LIMIT_MONTHLY="6"
TIMELINE_LIMIT_YEARLY="2"
"""


def _ensure_config(path: str) -> bool:
    """If the config is absent, interactively gather the essentials and write it, so
    setup-dest doubles as first-run onboarding. Returns True if a usable config exists
    afterwards. Never clobbers an existing config."""
    if os.path.isfile(path):
        return True
    if not sys.stdin.isatty():
        print(f"config {path} not found and not a tty to create it", file=sys.stderr)
        return False
    print(f"No config at {path} — let's create one.")

    def ask(prompt, default):
        v = input(f"  {prompt} [{default}]: ").strip()
        return v or default

    server_host = ask("Destination host (SERVER_HOST)", "")
    if not server_host:
        print("SERVER_HOST is required", file=sys.stderr)
        return False
    text = _CONFIG_TEMPLATE.format(
        server_host=server_host,
        ssh_port=ask("SSH port", "22"),
        server_user=ask("Transport user (SERVER_USER)", "snappersend"),
        ssh_key=ask("Transport SSH key path", "/etc/snappersend/ssh/id_ed25519"),
        recv_base=ask("Receive base on destination (btrfs)", "/srv/snapshots-recv"),
        subvolumes=ask("Subvolumes (name:mountpoint ...)", "root:/ home:/home"),
    )
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(text)
    except OSError as e:
        print(f"could not write {path}: {e}", file=sys.stderr)
        return False
    print(f"  wrote {path}")
    return True


def cmd_setup_dest(args: argparse.Namespace) -> int:
    """Onboard/repair the destination: ensure config + transport key, pin the host
    key, provision the destination over the admin login, then verify end-to-end."""
    if os.geteuid() != 0:
        print("setup-dest must run as root (writes /etc/snappersend + /root/.ssh). "
              "Try: sudo snappersend setup-dest <admin@host>", file=sys.stderr)
        return 2
    if not _ensure_config(args.config):
        return 2
    try:
        cfg = Config(**load_config(args.config))
    except Exception as e:
        print(f"invalid config {args.config}: {e}", file=sys.stderr)
        return 2

    resolved = _resolve_admin(args, cfg)
    if not resolved:
        return 2
    admin_user, host, port = resolved

    if not _ensure_transport_key(cfg):
        return 2
    try:
        pub = open(cfg.ssh_key + ".pub", encoding="utf-8").read().strip()
    except OSError as e:
        print(f"cannot read public key {cfg.ssh_key}.pub: {e}", file=sys.stderr)
        return 2

    _pin_host_key(cfg.server_host, cfg.server_ssh_port)

    print(f"Provisioning {cfg.server_user}@{cfg.server_host} (recv {cfg.recv_base}) "
          f"via admin login {admin_user}@{host} ...")
    rc, out, err = _run_admin_script(admin_user, host, port,
                                     _provision_script(cfg.server_user, pub, cfg.recv_base))
    # Interactive runs return no captured output (terminal inherited so sudo can
    # prompt); success is the exit code. When captured (non-interactive), also confirm
    # the sentinel and echo the detail line.
    if rc != 0 or (out and "PROVISION_OK" not in out):
        print(f"  provisioning FAILED (rc={rc}): {(err or out).strip() or 'see above'}",
              file=sys.stderr)
        return 1
    if out:
        print("  " + out.strip().splitlines()[-1])

    ok, msg = _verify_transport(cfg)
    print(("  verify: OK — " + msg) if ok else ("  verify: FAILED — " + msg))
    if ok:
        print(f"Done. Seed with:  sudo snappersend --dry-run   (then)  sudo snappersend")
    return 0 if ok else 1


def cmd_decom_dest(args: argparse.Namespace) -> int:
    """Remove the destination transport config (user + sudoers + key line) over the
    admin login. Received data is preserved unless --purge-data."""
    if os.geteuid() != 0:
        print("decom-dest must run as root. Try: sudo snappersend decom-dest <admin@host>",
              file=sys.stderr)
        return 2
    try:
        cfg = Config(**load_config(args.config))
    except FileNotFoundError:
        print(f"config not found: {args.config}", file=sys.stderr)
        return 2
    except Exception as e:
        print(f"invalid config {args.config}: {e}", file=sys.stderr)
        return 2

    resolved = _resolve_admin(args, cfg)
    if not resolved:
        return 2
    admin_user, host, port = resolved

    if args.purge_data:
        print(f"WARNING: --purge-data will DELETE this host's received snapshots under "
              f"{cfg.recv_base}/{socket.gethostname()} on {cfg.server_host}.")
        if sys.stdin.isatty():
            if input("Type 'purge' to confirm: ").strip() != "purge":
                print("aborted."); return 1

    script = _deprovision_script(cfg.server_user, cfg.recv_base,
                                 socket.gethostname(), args.purge_data)
    print(f"Decommissioning {cfg.server_user}@{cfg.server_host} via admin login "
          f"{admin_user}@{host} ...")
    rc, out, err = _run_admin_script(admin_user, host, port, script)
    if rc != 0 or (out and "DECOM_OK" not in out):
        print(f"  decom FAILED (rc={rc}): {(err or out).strip() or 'see above'}",
              file=sys.stderr)
        return 1
    for line in out.strip().splitlines():
        if line and line != "DECOM_OK user=" + cfg.server_user:
            print("  " + line)
    print(f"  removed transport user + sudoers on {cfg.server_host}"
          + ("" if args.purge_data else "; received data preserved"))
    return 0



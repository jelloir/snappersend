def _truthy(v: Optional[str]) -> bool:
    return v not in (None, "", "0", "false", "False", "no", "off")


def _add_config_flag(parser, suppress: bool = False) -> None:
    """--config, shared by the top level and each subcommand. Subcommand copies use
    SUPPRESS so putting --config before the subcommand isn't overwritten by a default."""
    parser.add_argument(
        "--config",
        default=(argparse.SUPPRESS if suppress
                 else os.environ.get("SNAPPERSEND_CONFIG", "/etc/snappersend/config")),
        help="config file (default /etc/snappersend/config, $SNAPPERSEND_CONFIG)")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="snappersend",
        description="Snapper-native Btrfs snapshot replication with a parent tree.",
    )
    _add_config_flag(p)
    p.add_argument("--server", "--dest", "--destination", default=None,
                   help="override the destination host from config ($SNAPPERSEND_SERVER)")
    p.add_argument("--subvol", default=None,
                   help="replicate only this subvolume (name from config)")
    p.add_argument("--dry-run", dest="dry_run", action="store_true", default=None,
                   help="log what would happen; change nothing ($SNAPPERSEND_DRY_RUN)")
    p.add_argument("--report", action="store_true",
                   help="read-only: show each subvol's current dest tiers + next-prune "
                        "KEEP/PRUNE, source clones + incremental parent, and chain/lag "
                        "health. Mutates nothing; mutually exclusive with a real run.")
    p.add_argument("--skip-boot", action="store_true",
                   help="skip the non-Btrfs /boot + /boot/efi rsync tier")
    p.add_argument("--no-mbuffer", action="store_true",
                   help="do not pipe through mbuffer even if configured")
    p.add_argument("-v", "--verbose", action="store_true", default=False,
                   help="log every shell command and extra detail")

    sub = p.add_subparsers(dest="command")

    sd = sub.add_parser("setup-dest",
                        help="provision the destination over an admin SSH login "
                             "(creates transport user + scoped sudoers; ships no files)")
    sd.add_argument("admin", nargs="?",
                    help="admin login on the destination, user@host (or bare user; "
                         "prompted if omitted). Your OWN sudo-capable account there.")
    _add_config_flag(sd, suppress=True)
    sd.add_argument("-v", "--verbose", action="store_true", default=argparse.SUPPRESS,
                    help="verbose")

    dd = sub.add_parser("decom-dest",
                        help="remove the destination transport config (preserves "
                             "received data unless --purge-data)")
    dd.add_argument("admin", nargs="?",
                    help="admin login on the destination, user@host (prompted if omitted)")
    dd.add_argument("--purge-data", action="store_true",
                    help="ALSO delete THIS host's received snapshots on the destination "
                         "(irreversible; asks for confirmation)")
    _add_config_flag(dd, suppress=True)
    dd.add_argument("-v", "--verbose", action="store_true", default=argparse.SUPPRESS,
                    help="verbose")

    return p


def main(argv: list[str]) -> int:
    args = build_parser().parse_args(argv)

    global _VERBOSE
    _VERBOSE = getattr(args, "verbose", False)
    if not hasattr(args, "config"):
        args.config = os.environ.get("SNAPPERSEND_CONFIG", "/etc/snappersend/config")

    command = getattr(args, "command", None)
    if command == "setup-dest":
        return cmd_setup_dest(args)
    if command == "decom-dest":
        return cmd_decom_dest(args)

    try:
        kwargs = load_config(args.config)
    except FileNotFoundError:
        log_error(f"config not found: {args.config}")
        return 2
    except Exception as e:   # KeyError / ValueError / dotenv issues
        log_error(f"invalid config {args.config}: {e}")
        return 2

    server = args.server or os.environ.get("SNAPPERSEND_SERVER")
    if server:
        kwargs["server_host"] = server

    if args.dry_run is not None:
        kwargs["dry_run"] = True
    elif "SNAPPERSEND_DRY_RUN" in os.environ:
        kwargs["dry_run"] = _truthy(os.environ.get("SNAPPERSEND_DRY_RUN"))

    if args.no_mbuffer:
        kwargs["use_mbuffer"] = False

    try:
        cfg = Config(**kwargs)
    except TypeError as e:
        log_error(f"config produced invalid settings: {e}")
        return 2

    if args.subvol and args.subvol not in cfg.subvols:
        log_error(f"--subvol {args.subvol!r} not in config subvols {list(cfg.subvols)}")
        return 2

    # --report is read-only and mutually exclusive with a real run: report, then exit
    # WITHOUT taking the run lock or entering replicate_subvol (it mutates nothing).
    if args.report:
        return _report(cfg, args)

    try:
        with run_lock():
            return _run(cfg, args)
    except _AlreadyRunning:
        return 1


def _run(cfg: Config, args: argparse.Namespace) -> int:
    hostname = socket.gethostname()
    log_step(f"snappersend on {hostname} -> {cfg.server_user}@{cfg.server_host}"
             + (" [DRY-RUN]" if cfg.dry_run else ""))

    snapshots_ok = True
    for name, sv in cfg.subvols.items():
        if args.subvol and name != args.subvol:
            continue
        recv_dir = cfg.recv_dir_for(hostname, name)
        try:
            ok = replicate_subvol(cfg, name, sv["mountpoint"], recv_dir)
        except Exception as e:
            log_error(f"[{name}] unexpected error: {e}")
            ok = False
        snapshots_ok = snapshots_ok and ok

    boot_ok = True
    if not args.skip_boot:
        try:
            boot_ok = boot_backup(cfg, hostname)
        except Exception as e:
            log_error(f"boot backup error: {e}")
            boot_ok = False

    if snapshots_ok and boot_ok:
        if not cfg.dry_run:
            _write_success_stamp()
        log_ok("snappersend finished: all tiers OK")
        return 0

    log_warn(f"snappersend finished with failures "
             f"(snapshots_ok={snapshots_ok} boot_ok={boot_ok}) — see log")
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

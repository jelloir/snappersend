#!/usr/bin/env bash
# snapsend-ssh-filter — forced command for the snapsend transport key (server side).
#
# Installed on the SERVER as /usr/local/bin/snapsend-ssh-filter and wired up in the
# snapsend user's authorized_keys:
#
#   command="/usr/local/bin/snapsend-ssh-filter",no-pty,no-agent-forwarding,\
#   no-port-forwarding,no-X11-forwarding ssh-ed25519 AAAA... laptop-snapsend
#
# It restricts what the laptop's key can run to exactly the command set
# di-snapsend issues over ssh — so even if the key leaks, it cannot get a shell or
# run arbitrary commands. This is defense-in-depth ON TOP of the scoped sudoers
# rule (/etc/sudoers.d/snapsend); neither alone is the whole story.
set -euo pipefail

cmd="${SSH_ORIGINAL_COMMAND:-}"

case "$cmd" in
    "sudo btrfs receive "*          | \
    "sudo btrfs subvolume show "*   | \
    "sudo btrfs subvolume delete "* | \
    "sudo btrfs property get "*     | \
    "sudo mkdir -p "*               | \
    "sudo rmdir "*                  | \
    "sudo ls "*                     | \
    "sudo ln -sfn "*                | \
    "sudo rsync "*)
        exec bash -c "$cmd"
        ;;
    *)
        echo "snapsend-ssh-filter: rejected command: ${cmd:-<none>}" >&2
        exit 1
        ;;
esac
